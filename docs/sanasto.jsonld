    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/linkitetty-data",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "linkitetty data",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "länkade data",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "linked data",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "rakenteinen data, joka on yhdistetty useiden tietoaineistojen sisältämään dataan linkkien avulla",
          "@language": "fi"
        },
        {
          "@value": "strukturerade data som har kombinerats med data i andra datauppsättningar med hjälp av länkar",
          "@language": "sv"
        },
        {
          "@value": "structured data that is connected to the data in several datasets with the help of links",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Linkitetty data voi olla avointa dataa, jolloin sitä kutsutaan avoimeksi linkitetyksi dataksi.",
          "@language": "fi"
        },
        {
          "@value": "Länkade data kan vara öppna data, och kallas i sådant fall länkade öppna data.",
          "@language": "sv"
        },
        {
          "@value": "Linked data can be open data, in which case it is referred to as linked open data.",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Yhteentoimivuusalustan sanasto",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/yti/concept-7"
        },
        {
          "@value": "ISO 5127:2017",
          "@language": "en",
          "@id": "https://www.iso.org"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/data"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/RDF",
        "https://teemualaluusua.github.io/sanasto1/URI",
        "https://teemualaluusua.github.io/sanasto1/ontologia",
        "https://teemualaluusua.github.io/sanasto1/semanttinen web"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-17T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/lokitiedosto",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "lokitiedosto",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "loggfil",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "log file",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "palvelimen automaattisesti luoma tiedosto, joka sisältää tietoa palvelimella tehdyistä toimenpiteistä",
          "@language": "fi"
        },
        {
          "@value": "fil som automatiskt skapas av en server och som innehåller information om aktiviteter som utförs på servern",
          "@language": "sv"
        },
        {
          "@value": "file automatically created by a server that maintains a record of its activities",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Lokitiedostoja käytetään järjestelmien valvontaan,\nvirheiden jäljittämiseen ja tietoturvatapahtumien\nanalysointiin.\n",
          "@language": "fi"
        },
        {
          "@value": "Loggfiler används för övervakning av system,\nfelsökning och analys av säkerhetshändelser.\n",
          "@language": "sv"
        },
        {
          "@value": "Log files are commonly used for system monitoring,\ntroubleshooting and security auditing.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO 5127:2022",
          "@language": "en",
          "@id": "https://www.iso.org"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/käsitemalli"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/tietomalli",
        "https://teemualaluusua.github.io/sanasto1/ontologia"
      ],
      "dcterms:created": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-15T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/lokitieto",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "lokitieto",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "loggdata",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "log data",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "tietojärjestelmän muistiin automaattisesti kirjautuva tapahtumatieto",
          "@language": "fi"
        },
        {
          "@value": "händelseinformation som automatiskt registreras i ett informationssystems minne",
          "@language": "sv"
        },
        {
          "@value": "event information that is automatically recorded in the memory of an information system",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Yhteentoimivuusalustan sanasto",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/yti/concept-59"
        },
        {
          "@value": "ISO 26430-4:2009",
          "@language": "fi",
          "@id": "https://www.iso.org/"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/tieto"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/lokitiedosto",
        "https://teemualaluusua.github.io/sanasto1/tietoturva",
        "https://teemualaluusua.github.io/sanasto1/tapahtumatieto"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-17T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/looginen-tietomalli",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "looginen tietomalli",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "logisk datamodell",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "logical data model",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "tietomalli, joka kuvaa tiedot ja tietorakenteet loogisella tasolla",
          "@language": "fi"
        },
        {
          "@value": "datamodell som beskriver data och datastrukturer på en logisk nivå",
          "@language": "sv"
        },
        {
          "@value": "data model that describes data and data structures at a logical level",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Looginen tietomalli kuvaa tarkastelun kohteena olevat luokat, niiden väliset assosiaatiot (suhteet) ja luokkiin sisältyvät attribuutit.",
          "@language": "fi"
        },
        {
          "@value": "Looginen tietomalli on käsitemallista tarkemmalle tasolle viety kuvaus.",
          "@language": "fi"
        },
        {
          "@value": "Den logiska datamodellen beskriver de klasser som analyseras, relationerna (associationerna) mellan dem samt de attribut som ingår i klasserna.",
          "@language": "sv"
        },
        {
          "@value": "Den logiska datamodellen är en mer detaljerad beskrivning än en begreppsmodell.",
          "@language": "sv"
        },
        {
          "@value": "The logical data model describes the classes under consideration, the associations (relationships) between them, and the attributes contained within the classes.",
          "@language": "en"
        },
        {
          "@value": "The logical data model is a more detailed representation than a conceptual model.",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Yhteentoimivuusalustan sanasto",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/yti/concept-73"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/tietomalli"
      ],
      "skos:narrower": [
        "https://teemualaluusua.github.io/sanasto1/fyysinen tietomalli"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/käsitemalli",
        "https://teemualaluusua.github.io/sanasto1/käsiteskeema",
        "https://teemualaluusua.github.io/sanasto1/luokka",
        "https://teemualaluusua.github.io/sanasto1/attribuutti"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
