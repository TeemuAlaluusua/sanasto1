    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/tietomääritys",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "tietomääritys",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "informationsspecifikation",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "information specification",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "tiedon täsmällinen kuvaus koodistona, sanastona tai tietomallina",
          "@language": "fi"
        },
        {
          "@value": "noggrann beskrivning av information som kodsystem, terminologi eller datamodell",
          "@language": "sv"
        },
        {
          "@value": "precise description of information as a code list, vocabulary or data model",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Tietomääritys-käsitettä käytetään yläkäsitteenä erilaisista tietokuvauksista.",
          "@language": "fi"
        },
        {
          "@value": "Begreppet informationsspecifikation används som ett överordnat begrepp för olika typer av informationsbeskrivningar.",
          "@language": "sv"
        },
        {
          "@value": "The concept of information specification is used as a general concept for different types of information descriptions.",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Yhteentoimivuusalustan sanasto",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/yti/concept-55"
        }
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/tietomalli",
        "https://teemualaluusua.github.io/sanasto1/sanasto",
        "https://teemualaluusua.github.io/sanasto1/koodisto"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-17T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/tietopankki",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "tietopankki",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "databank",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "data repository",
          "@language": "en",
          "termType": "Suositettava termi"
        },
        {
          "@value": "data bank",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "joukko tiedostoja tai tietokantoja, joilla on yhteinen varastointijärjestelmä, käsittelyjärjestelmä ja hakujärjestelmä",
          "@language": "fi"
        },
        {
          "@value": "samling filer eller databaser som har ett gemensamt lagringssystem, behandlingssystem och söksystem",
          "@language": "sv"
        },
        {
          "@value": "set of files or databases combined with a storage system, a processing system and a retrieval system",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Tietopankki tarkoittaa järjestettyä kokonaisuutta, jossa tietoa\ntallennetaan, ylläpidetään ja haetaan yhtenäisen järjestelmän avulla.\nTermiä käytetään usein yleisnimityksenä järjestelmälle, joka kokoaa\nuseita tietokantoja tai tiedostoja yhteen hallittuun tietovarastoon.\n",
          "@language": "fi"
        },
        {
          "@value": "En databank är en organiserad helhet där information lagras, underhålls\noch hämtas med hjälp av ett enhetligt system. Termen används ofta som\nen allmän beteckning för ett system som samlar flera databaser eller\nfiler i ett gemensamt hanterat informationslager.\n",
          "@language": "sv"
        },
        {
          "@value": "A data repository or data bank refers to an organised collection in\nwhich information is stored, maintained and retrieved through a\nunified system. The term is often used as a general designation for a\nsystem that brings together several databases or files into a managed\ninformation storage environment.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO 5127:2022 Information and documentation — Foundation and vocabulary",
          "@language": "en",
          "@id": "https://www.iso.org/standard/59743.html"
        }
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/tietovaranto",
        "https://teemualaluusua.github.io/sanasto1/tietokanta",
        "https://teemualaluusua.github.io/sanasto1/tietovarasto"
      ],
      "dcterms:created": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/tietoturva",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "Tietoturva",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "informationssäkerhet",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "information security",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "Tietoturvalla (engl. information security) tarkoitetaan fyysistä ja digitaalista\ntiedon suojaamista. Fyysinen suojaaminen voi pitää sisällään toimenpiteitä, jotka\nsuojaavat tietokoneita varastavalta murtovarkaalta. Digitaalinen suojaaminen eli\nkyberturvallisuus (engl. cyber security) tarkoittaa suojautumista verkon kautta\ntulevilta hyökkäyksiltä ja tietomurroilta. Tietoturvalla on kolme päätavoitetta:\nTiedon luottamuksellisuuden, eheyden ja saatavuuden varmistaminen.\n\n1 Luottamuksellisuus (engl. confidentiality) tarkoittaa, ettei tieto saa vuotaa\nulkopuolisille.\n\n2 Eheys (engl. integrity) tarkoittaa, että järjestelmät ovat luotettavia ja että\ntieto säilyy muuttumattomana ja on ajantasaisesti varmuuskopioitu.\n\n3 Saatavuus (engl. availability) tarkoittaa pääsyä tietoon silloin, kun sitä tarvitaan.\n",
          "@language": "fi"
        },
        {
          "@value": "Informationssäkerhet avser skydd av information både fysiskt och digitalt. Fysiskt skydd kan omfatta åtgärder som skyddar datorer mot stöld. Digitalt skydd, det vill säga cybersäkerhet, avser skydd mot attacker och dataintrång via nätverk. Informationssäkerhet har tre huvudmål: att säkerställa informationens konfidentialitet, integritet och tillgänglighet.\n\n1 Konfidentialitet innebär att information inte får spridas till obehöriga.\n\n2 Integritet innebär att system är tillförlitliga och att informationen förblir oförändrad samt är korrekt säkerhetskopierad.\n\n3 Tillgänglighet innebär att information är åtkomlig när den behövs.\n",
          "@language": "sv"
        },
        {
          "@value": "Information security refers to the protection of information both physically and digitally. Physical protection may include measures that protect computers from theft. Digital protection, i.e. cybersecurity, refers to protection against attacks and data breaches via networks. Information security has three main objectives: ensuring the confidentiality, integrity and availability of information.\n\n1 Confidentiality means that information must not be disclosed to unauthorized parties.\n\n2 Integrity means that systems are reliable and that information remains unaltered and is properly backed up.\n\n3 Availability means that information is accessible when needed.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO/IEC 27000:2020",
          "@language": "fi",
          "@id": "https://www.iso.org/"
        }
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-17T17:35",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/tietue",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "tietue",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "post",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "record",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "dokumentin osa tai dokumentti, joka sisältää rakenteellisen ja sisäisesti järjestetyn joukon itsenäistä mutta toisiinsa liittyvää dataa, joka koskee yhtä henkilöä tai muuta oliota ja joka on valittu ja esitetty tiettyä tarkoitusta varten",
          "@language": "fi"
        },
        {
          "@value": "del av ett dokument eller dokument som innehåller en strukturerad och internt organiserad uppsättning självständiga men relaterade data om en person eller annat objekt, valda och presenterade för ett specifikt syfte",
          "@language": "sv"
        },
        {
          "@value": "part of a document or document containing a structured and internally organized set of self-contained but related data on one person or other object, selected and presented for a predefined specific purpose",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Tietue koostuu yleensä useista kentistä,\njotka kuvaavat tietyn kohteen ominaisuuksia.\n",
          "@language": "fi"
        },
        {
          "@value": "En post består vanligtvis av flera fält\nsom beskriver egenskaper hos ett visst objekt.\n",
          "@language": "sv"
        },
        {
          "@value": "A record typically consists of several\nfields describing attributes of a given object.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO 5127:2022",
          "@language": "en",
          "@id": "https://www.iso.org"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/tietokanta"
      ],
      "skos:narrower": [
        "https://teemualaluusua.github.io/sanasto1/kenttä"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/tietokohde",
        "https://teemualaluusua.github.io/sanasto1/tietorakenne"
      ],
      "dcterms:created": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/uri",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "URI",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "Uniform Resource Identifier",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "URI",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "Uniform Resource Identifier",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "URI",
          "@language": "en",
          "termType": "Suositettava termi"
        },
        {
          "@value": "Uniform Resource Identifier",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "merkkijonosta muodostuva tunnus, joka yksikäsitteisesti yksilöi tietyn verkkoresurssin noudattaen sovittua syntaksia",
          "@language": "fi"
        },
        {
          "@value": "en teckensträng som entydigt identifierar en specifik nätverksresurs enligt en överenskommen syntax",
          "@language": "sv"
        },
        {
          "@value": "a global identifier in the context of the World Wide Web",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "URI-tunnistetta käytetään tyypillisesti World Wide Webin verkkoresurssien yksilöimisessä.",
          "@language": "fi"
        },
        {
          "@value": "URI on verkossa olevan sisällön yksilöllinen tunniste. URI:lle on määritetty muoto,\njoka toimii samalla tavalla kuin URL. URI-muodossa määritellään sisällön muoto\n(esim. ”http:” verkkosivulle tai ”mailto:” sähköpostille) ja sisällön sijainti\n(esim. ”ym.fi” verkkosivulle tai sähköpostiosoite). URI-muodon tarkoituksena on\nilmaista mistä ja missä muodossa haettu tieto löytyy. Tietomallin sisällöissä\nURI-muoto viittaa usein liitetiedostojen sijaintiin palvelimella.\n",
          "@language": "fi"
        },
        {
          "@value": "URI används vanligtvis för att identifiera resurser på World Wide Web.",
          "@language": "sv"
        },
        {
          "@value": "URI är en unik identifierare för innehåll på nätet. URI har ett definierat format\nsom liknar URL. I URI-formatet anges innehållets typ (t.ex. ”http:” för webbsidor\neller ”mailto:” för e-post) och dess plats. Syftet med URI är att ange var och i\nvilken form information finns. I informationsmodeller används URI ofta för att\nreferera till bilagors placering på en server.\n",
          "@language": "sv"
        },
        {
          "@value": "URI is typically used to identify resources on the World Wide Web.",
          "@language": "en"
        },
        {
          "@value": "A URI is a unique identifier for content on the web. It follows a defined format\nsimilar to a URL. A URI specifies both the type of the resource (e.g. “http:” or\n“mailto:”) and its location. The purpose of a URI is to indicate where and in\nwhat form information can be found. In data models, URIs often refer to the\nlocation of attachments on a server.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Yhteentoimivuusalustan sanasto",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/yti/concept-32"
        },
        {
          "@value": "RYHTI-sanasto",
          "@language": "fi",
          "@id": "https://ryhti.syke.fi/ohjeet-ja-tuki/ryhti-sanasto/"
        }
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/url",
        "https://teemualaluusua.github.io/sanasto1/tunniste",
        "https://teemualaluusua.github.io/sanasto1/yksilöintitieto"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-17T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/vaihtoformaatti",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "vaihtoformaatti",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "utbytesformat",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "exchange format",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "koneluettava dataformaatti, jonka avulla tieto esitetään sellaisessa muodossa, jossa sitä voidaan vaihtaa eri sovellusten välillä",
          "@language": "fi"
        },
        {
          "@value": "maskinläsbart dataformat som används för att representera information i en form som möjliggör utbyte mellan olika applikationer",
          "@language": "sv"
        },
        {
          "@value": "machine-readable data format for representing information that is intended to facilitate exchange of the information between different applications",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Vaihtoformaatteja käytetään tietojen siirtämiseen\neri tietojärjestelmien tai ohjelmistojen välillä\nyhteentoimivuuden varmistamiseksi.\n",
          "@language": "fi"
        },
        {
          "@value": "Utbytesformat används för att överföra information\nmellan olika informationssystem eller programvara\nför att möjliggöra interoperabilitet.\n",
          "@language": "sv"
        },
        {
          "@value": "Exchange formats are used to transfer information\nbetween different information systems or software\napplications to enable interoperability.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO 5127:2022",
          "@language": "en",
          "@id": "https://www.iso.org/standard/59743.html"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/dataformaatti"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/tiedostoformaatti",
        "https://teemualaluusua.github.io/sanasto1/säilytysformaatti"
      ],
      "dcterms:created": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/valintalista",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "Valintalista",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "valbar lista",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "pick list",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "Valintalista on digitaalisen graafisen käyttöliittymän elementti, joka tarjoaa käyttäjälle mahdollisuuden valita vaihtoehtoja, kuten termejä valmiilta listalta.",
          "@language": "fi"
        },
        {
          "@value": "En vallista är ett element i ett digitalt grafiskt användargränssnitt som ger användaren möjlighet att välja alternativ, såsom termer, från en fördefinierad lista.",
          "@language": "sv"
        },
        {
          "@value": "A pick list is an element of a digital graphical user interface that allows the user to select options, such as terms, from a predefined list.",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO 5127:2017",
          "@language": "fi",
          "@id": "https://www.iso.org/"
        }
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/versio",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "Versio",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "version",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "version",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "Tietosisällöt, joilla on sama käyttötarkoitus, mutta eri voimassaoloaika ja joiden sisältö voi poiketa toisistaan. Versio on yksittäisen sanaston, koodiston tai tietomallin uusi tai vanha versio. Niiden voimassaolon alkamis- ja päättymispäivämäärät poikkeavat toisistaan. Tyypillisesti uusi versio korvaa vanhan version.",
          "@language": "fi"
        },
        {
          "@value": "Informationsinnehåll med samma användningsändamål men med olika giltighetstid och vars innehåll kan skilja sig från varandra. En version är en ny eller gammal version av ett enskilt begreppssystem, kodsystem eller informationsmodell. Deras giltighetsperioder börjar och slutar vid olika tidpunkter. Vanligtvis ersätter en ny version den gamla versionen.",
          "@language": "sv"
        },
        {
          "@value": "Information contents that have the same purpose of use but different validity periods and whose content may differ from each other. A version is a new or old version of a specific terminology, code system or data model. Their validity start and end dates differ. Typically, a new version replaces the old version.",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Sanastot",
          "@language": "fi",
          "@id": "https://sanastot.suomi.fi/"
        }
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/vertailuanalysointi",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "Vertailuanalysointi",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "benchmarking",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "benchmarking",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "Vertailuanalysointi tarkoittaa oman toiminnan vertaamista toisten toimintaan, usein parhaaseen vastaavaan käytäntöön. Vertailuanalysoinnin perusidea on toisilta oppiminen ja oman toiminnan kyseenalaistaminen.",
          "@language": "fi"
        },
        {
          "@value": "Benchmarking innebär att jämföra den egna verksamheten med andras verksamhet, ofta med bästa motsvarande praxis. Grundidén med benchmarking är att lära av andra och att ifrågasätta den egna verksamheten.",
          "@language": "sv"
        },
        {
          "@value": "Benchmarking refers to comparing one's own activities with those of others, often with the best corresponding practices. The basic idea of benchmarking is learning from others and questioning one's own operations.",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO/IEC 29155-1:2011",
          "@language": "fi",
          "@id": "https://www.iso.org/"
        }
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/xbrl",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "XBRL",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "eXtensible Business Reporting Language",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "XBRL",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "eXtensible Business Reporting Language",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "XBRL",
          "@language": "en",
          "termType": "Suositettava termi"
        },
        {
          "@value": "eXtensible Business Reporting Language",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "kuvauskieli, jolla taloudelliset tiedot kuvataan sähköisessä ja rakenteisessa muodossa",
          "@language": "fi"
        },
        {
          "@value": "beskrivningsspråk för att uttrycka finansiell information i elektronisk och strukturerad form",
          "@language": "sv"
        },
        {
          "@value": "open international standard for digital business reporting",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "XBRL pohjautuu XML-kieleen (Extensible Markup Language), joka on metakieli rakenteellisten kuvauskielten kehittämiseksi. XML:llä saadaan aikaan dokumentteja, joiden rakenne on erotettu sen tietosisällöstä.",
          "@language": "fi"
        },
        {
          "@value": "XBRL:ää hallinnoi kansainvälinen voittoa tavoittelematon organisaatio XBRL International.",
          "@language": "fi"
        },
        {
          "@value": "XBRL bygger på XML (Extensible Markup Language), som är ett metaspråk för att utveckla strukturerade beskrivningsspråk. Med XML kan man skapa dokument där strukturen är åtskild från informationsinnehållet.",
          "@language": "sv"
        },
        {
          "@value": "XBRL förvaltas av en global ideell organisation, XBRL International.",
          "@language": "sv"
        },
        {
          "@value": "XBRL is based on XML (Extensible Markup Language), which is a meta-language for developing structured description languages. XML enables documents where the structure is separated from the content.",
          "@language": "en"
        },
        {
          "@value": "XBRL is managed by a global not for profit consortium, XBRL International.",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Yhteentoimivuusalustan sanasto",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/yti/concept-43"
        }
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/xml",
        "https://teemualaluusua.github.io/sanasto1/tietomalli",
        "https://teemualaluusua.github.io/sanasto1/raportointi"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-17T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/ydintieto",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "ydintieto",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "masterdata",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "master data",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "organisaation toimintaan liittyvää kohdetta kuvaava tieto, jota useampi organisaation prosessi tai toiminto tarvitsee tai hyödyntää",
          "@language": "fi"
        },
        {
          "@value": "information som beskriver ett objekt kopplat till organisationens verksamhet och som används eller behövs av flera processer eller funktioner inom organisationen",
          "@language": "sv"
        },
        {
          "@value": "the authoritative, most accurate data that is available about key business entities, used to establish the context for business transactions and transactional data",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Organisaation masterdataa voivat olla esimerkiksi asiakkaita, toimittajia, yhteistyökumppaneita, tuotteita, palveluita tai toimipaikkoja koskevat tiedot. Tavallisesti master data on hitaasti muuttuvaa ja sen tarve on pitkäaikaista.",
          "@language": "fi"
        },
        {
          "@value": "Organisationens masterdata kan till exempel omfatta uppgifter om kunder, leverantörer, samarbetspartner, produkter, tjänster eller verksamhetsställen. Masterdata förändras vanligtvis långsamt och används under lång tid.",
          "@language": "sv"
        },
        {
          "@value": "Master data in an organization may include information about customers, suppliers, partners, products, services or locations. Master data is typically slowly changing and used over a long period.",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Yhteentoimivuusalustan sanasto",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/yti/concept-58"
        }
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/tieto",
        "https://teemualaluusua.github.io/sanasto1/tietomalli"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-17T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/yhteentoimivuus",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "yhteentoimivuus",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "interoperabilitet",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "interoperability",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "toimintaan liittyvien toimijoiden, prosessien ja tietojärjestelmien kyky toimia ja viestiä keskenään sellaisella tavalla tai siinä laajuudessa, että ne voivat rutiininomaisesti käyttää ja ymmärtää toistensa tietoja",
          "@language": "fi"
        },
        {
          "@value": "förmåga hos aktörer, processer och informationssystem som är kopplade till en verksamhet att fungera och kommunicera med varandra på ett sådant sätt eller i sådan omfattning att de rutinmässigt kan använda och förstå varandras information",
          "@language": "sv"
        },
        {
          "@value": "ability of actors, processes and information systems that are connected to an activity to act and communicate together in such a way or scope that they can routinely use and understand each other's data",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Yhteentoimivuus voi olla luonteeltaan teknistä, semanttista, organisatorista tai oikeudellista.",
          "@language": "fi"
        },
        {
          "@value": "Interoperabilitet kan vara teknisk, semantisk, organisatorisk eller juridisk till sin natur.",
          "@language": "sv"
        },
        {
          "@value": "Interoperability can be technical, semantic, organisational or legal in nature.",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Yhteentoimivuusalustan sanasto",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/yti/concept-9"
        },
        {
          "@value": "ISO/IEC 22123-1:2023",
          "@language": "en",
          "@id": "https://www.iso.org/standard/82758.html"
        }
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-17T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/yhteentoimivuusalusta",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "yhteentoimivuusalusta",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "interoperabilitetsplattform",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "interoperability platform",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "FI-Platform",
          "@language": "fi",
          "termType": "Synonyymi"
        }
      ],
      "skos:definition": [
        {
          "@value": "sanastoista, koodistoista ja tietomalleista sekä niiden käyttöön ja muokkaukseen tarkoitetuista työkaluista muodostuva kokonaisuus, jonka tarkoituksena on edistää yhteentoimivuutta",
          "@language": "fi"
        },
        {
          "@value": "helhet bestående av terminologier, kodsystem och informationsmodeller samt verktyg för deras användning och redigering, vars syfte är att främja interoperabilitet",
          "@language": "sv"
        },
        {
          "@value": "a set consisting of vocabularies, code lists and data models as well as tools for their use and maintenance, intended to promote interoperability",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Suomen Digi- ja väestötietoviraston (DVV) ylläpitämä yhteentoimivuusalusta on kokoelma\ntyökaluja, joiden käyttö on vapaata ja avointa. Työkaluilla voidaan laatia sanastoja,\nkoodistoja ja loogisia tietomalleja, joita voidaan jakaa eri toimijoiden kesken.\nPalvelu on tarkoitettu niin julkisille kuin yksityisille toimijoille. Palvelun\ntarkoitus on vähentää päällekkäistä työtä, kun jo kertaalleen määriteltyjä\nkokonaisuuksia voi hyödyntää uusien projektikokonaisuuksien pohjalla.\n",
          "@language": "fi"
        },
        {
          "@value": "Interoperabilitetsplattformen som upprätthålls av Myndigheten för digitalisering och befolkningsdata i Finland (DVV) är en samling verktyg som är fritt och öppet tillgängliga.\nMed verktygen kan man skapa terminologier, kodsystem och logiska datamodeller\nsom kan delas mellan olika aktörer. Tjänsten är avsedd för både offentliga och\nprivata aktörer. Syftet med tjänsten är att minska överlappande arbete genom att\nredan definierade helheter kan återanvändas som grund för nya projekt.\n",
          "@language": "sv"
        },
        {
          "@value": "The interoperability platform maintained by the Digital and Population Data Services Agency of Finland (DVV) is a collection of tools that are freely and openly available.\nThe tools can be used to create vocabularies, code lists and logical data models\nthat can be shared between different stakeholders. The service is intended for\nboth public and private actors. Its purpose is to reduce overlapping work by\nenabling previously defined entities to be reused as a basis for new projects.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Yhteentoimivuusalustan sanasto",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/yti/concept-8"
        }
      ],
      "dcterms:created": {
        "@value": "2026-03-17T00:00",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-17T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/yksilöinti",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "Yksilöinti",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "Identifiering",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "Identification",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "Toimijan, kohteen tai tietomallin objektin yksiselitteinen tunnistaminen ja erottaminen muista samaan joukkoon kuuluvista.",
          "@language": "fi"
        },
        {
          "@value": "Entydig identifiering av en aktör, ett objekt eller ett objekt i en informationsmodell samt särskiljning från andra som tillhör samma mängd.",
          "@language": "sv"
        },
        {
          "@value": "Unambiguous identification of an actor, an object or an object in an information model and distinguishing it from others belonging to the same set.",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Yksilöinti toteutetaan liittämällä kohteeseen yksilöintitieto, kuten tunnus, koodi tai globaalitunniste (esim. GUID). Rakentamisen tietomalleissa yksilöinti mahdollistaa objektien elinkaaren aikaisen viittauksen, jäljitettävyyden ja tiedonhallinnan.",
          "@language": "fi"
        },
        {
          "@value": "Identifiering genomförs genom att koppla en identifieringsuppgift till objektet, såsom en beteckning, kod eller global identifierare (t.ex. GUID). I byggandets informationsmodeller möjliggör identifiering livscykelbaserad referens, spårbarhet och informationshantering av objekt.",
          "@language": "sv"
        },
        {
          "@value": "Identification is implemented by associating identifying information with the object, such as an identifier, code or global identifier (e.g. GUID). In construction information models, identification enables lifecycle referencing, traceability and information management of objects.",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Suomi.fi-sanastot: Yritysdigi – yksilöinti",
          "@language": "fi",
          "@id": "https://sanastot.suomi.fi/terminology/yritysdigi/concept/concept-2065"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/tunnistaminen"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/yksilöintitieto",
        "https://teemualaluusua.github.io/sanasto1/tunniste",
        "https://teemualaluusua.github.io/sanasto1/GUID",
        "https://teemualaluusua.github.io/sanasto1/tietomalliobjekti"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-17T10:55:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/yksilöintitieto",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "Yksilöintitieto",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "Identifieringsuppgift",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "Identifying information",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "Tieto tai tietojoukko, jonka avulla toimija, kohde tai tietomallin objekti voidaan yksiselitteisesti tunnistaa ja erottaa muista.",
          "@language": "fi"
        },
        {
          "@value": "Uppgift eller uppsättning uppgifter med vilka en aktör, ett objekt eller ett objekt i en informationsmodell kan identifieras entydigt och särskiljas från andra.",
          "@language": "sv"
        },
        {
          "@value": "Information or a set of information by which an actor, an object or an object in an information model can be uniquely identified and distinguished from others.",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Yksilöintitieto voi olla yksittäinen tunniste (esim. tunnus, koodi, GUID) tai tunnisteiden yhdistelmä. Rakentamisen tietomalleissa yksilöintitieto liitetään esimerkiksi rakennusosiin, järjestelmiin, tiloihin ja laitteisiin elinkaaren aikaisen jäljitettävyyden ja hallinnan varmistamiseksi.",
          "@language": "fi"
        },
        {
          "@value": "Identifieringsuppgifter kan vara en enskild identifierare (t.ex. beteckning, kod, GUID) eller en kombination av identifierare. I byggandets informationsmodeller kopplas identifieringsuppgifter till exempel till byggnadsdelar, system, utrymmen och utrustning för att säkerställa spårbarhet och hantering under livscykeln.",
          "@language": "sv"
        },
        {
          "@value": "Identifying information can consist of a single identifier (e.g. identifier, code, GUID) or a combination of identifiers. In construction information models, identifying information is associated for example with building elements, systems, spaces and equipment to ensure lifecycle traceability and management.",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Suomi.fi-sanastot: Yritysdigi – yksilöintitieto",
          "@language": "fi",
          "@id": "https://sanastot.suomi.fi/terminology/yritysdigi/concept/concept-2062"
        }
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-02-27T10:48:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/ylävirta",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "ylävirta",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "uppströms",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "upstream",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "Toimitusketjun osa, joka kattaa vaiheet ja toimijat raaka-ainelähteistä ja toimittajista kokoonpanevaan tai tuottavaan yksikköön. Vastakohta alavirralle. Kutsutaan myös hankintapääksi tai hankintamarkkinoiksi.",
          "@language": "fi"
        },
        {
          "@value": "Den del av leveranskedjan som omfattar skeden och aktörer från råvarukällor och leverantörer till den producerande eller monterande enheten. Motsats till nedströms.",
          "@language": "sv"
        },
        {
          "@value": "The part of a supply chain that includes the stages and actors from raw material sources and suppliers to the producing or assembling unit. The opposite of downstream.",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Termiä käytetään toimitusketjun tarkastelussa kuvaamaan virtausta kohti\ntuotantoa tai kokoonpanoa. Rakentamisen kontekstissa ylävirta voi tarkoittaa\nesimerkiksi materiaalien ja komponenttien toimitusketjua raaka-aineista\nelementtitehtaalle tai työmaalle.\n",
          "@language": "fi"
        },
        {
          "@value": "Termen används vid analys av leveranskedjor för att beskriva flödet mot\nproduktion eller montering. I byggsektorn kan uppströms till exempel\navse leveranskedjan för material och komponenter från råvaror till\nelementfabrik eller byggarbetsplats.\n",
          "@language": "sv"
        },
        {
          "@value": "The term is used in supply chain analysis to describe the flow towards\nproduction or assembly. In the construction context, upstream may refer\nto the supply chain of materials and components from raw materials to a\nprefabrication plant or construction site.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Logistiikan maailma -termisanasto (2025)",
          "@language": "fi",
          "@id": "https://www.logistiikanmaailma.fi/aineistot/sanastot/logistiikan-maailma-termisanasto/"
        }
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/alavirta"
      ],
