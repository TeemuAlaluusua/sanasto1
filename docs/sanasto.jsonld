    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/attribuutti",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "attribuutti",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "attribut",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "attribute",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "attribuuttitieto",
          "@language": "fi",
          "termType": "Synonyymi"
        },
        {
          "@value": "attributdata",
          "@language": "sv",
          "termType": "Synonyymi"
        }
      ],
      "skos:definition": [
        {
          "@value": "tietomallissa luokkaa luonnehtiva tai kuvaava ominaisuus\n",
          "@language": "fi"
        },
        {
          "@value": "egenskap i en informationsmodell som beskriver eller kännetecknar en klass\n",
          "@language": "sv"
        },
        {
          "@value": "characteristic in an information model that describes or characterizes a class\n",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Attribuutti on tietomallissa objektin määrittelyyn\nkuuluva rakenteellinen tietokenttä, joka kuvaa objektin ominaisuutta.\nAttribuutti on osa objektin luokan rakennetta ja sillä on ennalta\nmääritelty merkitys ja tietotyyppi. Esimerkkejä ovat nimi, tunnus,\nsijainti, tyyppi tai materiaali.\n\nTietomallinnuksessa attribuutti erotetaan usein ominaisuudesta\n(engl. property). Attribuutti on objektin luokan sisäinen,\nrakenteellinen kenttä, kun taas ominaisuus on yleensä erillinen,\nlaajennettava ominaisuustieto (esim. BIM-propertysetissä).\n",
          "@language": "fi"
        },
        {
          "@value": "Ett attribut är i en informationsmodell ett strukturellt\ndatafält som ingår i definitionen av ett objekt och beskriver en egenskap\nhos objektet. Attributet är en del av objektklassens struktur och har en\nfördefinierad betydelse och datatyp. Exempel är namn, identifierare,\nläge, typ eller material.\n\nI informationsmodellering skiljer man ofta mellan attribut och egenskap\n(eng. property). Ett attribut är ett internt, strukturellt fält i en\nobjektklass, medan en egenskap vanligtvis är en separat och utbyggbar\negenskapsuppgift (t.ex. i ett BIM-propertyset).\n",
          "@language": "sv"
        },
        {
          "@value": "An attribute is a structural data field in an information model that is\npart of the definition of an object and describes a characteristic of that\nobject. An attribute belongs to the structure of an object class and has a\npredefined meaning and data type. Examples include name, identifier,\nlocation, type, or material.\n\nIn information modelling, an attribute is often distinguished from a\nproperty. An attribute is an internal structural field of an object class,\nwhereas a property is typically a separate and extensible piece of\ndescriptive information (for example in a BIM property set).\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "RYHTI-sanasto",
          "@language": "fi",
          "@id": "https://ryhti.syke.fi/ohjeet-ja-tuki/ryhti-sanasto/"
        },
        {
          "@value": "Sanastot.suomi.fi",
          "@language": "fi",
          "@id": "https://sanastot.suomi.fi/terminology/yti/concept/concept-24"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/objekti"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/ominaisuus",
        "https://teemualaluusua.github.io/sanasto1/attribuutin-arvo",
        "https://teemualaluusua.github.io/sanasto1/tietokenttä"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-02-27T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/automatisoitu",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "automatisoitu",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "automaattinen",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "automaatio",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "automatic",
          "@language": "en",
          "termType": "Suositettava termi"
        },
        {
          "@value": "automation",
          "@language": "en",
          "termType": "Suositettava termi"
        },
        {
          "@value": "automated",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "Prosessi tai järjestelmä, joka tietyissä olosuhteissa toimii ilman ihmisen puuttumista.\n",
          "@language": "fi"
        },
        {
          "@value": "process eller system som under angivna förhållanden fungerar utan mänsklig inblandning\n",
          "@language": "sv"
        },
        {
          "@value": "Pertaining to a process or system that, under specified conditions, functions without human intervention\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO/IEC 22989:2023"
        }
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/avoin-data",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "avoin data",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "öppna data",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "open data",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "data, joka on tarjolla muille ja jota kuka tahansa saa vapaasti\nkäyttää, kierrättää, julkaista uudelleen ja levittää edelleen.\n",
          "@language": "fi"
        },
        {
          "@value": "data som är tillgängliga för andra och som vem som helst fritt\nfår använda, återanvända, publicera på nytt och vidareförmedla.\n",
          "@language": "sv"
        },
        {
          "@value": "data that are available to others and that anyone may freely\nuse, reuse, republish and redistribute.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO 5127:2022",
          "@language": "en"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/data"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/bcf",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "bim collaboration format",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "bim collaboration format",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "bim collaboration format",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "BCF",
          "@language": "fi",
          "termType": "Lyhenne"
        },
        {
          "@value": "BCF",
          "@language": "sv",
          "termType": "Lyhenne"
        },
        {
          "@value": "BCF",
          "@language": "en",
          "termType": "Lyhenne"
        }
      ],
      "skos:definition": [
        {
          "@value": "Standardi, jolla vaihdetaan tietoja IFC-tietoaineiston\nsisällöstä. Tietoja voidaan vaihtaa ZIP-tiedostossa\n(XML-muodossa) tai rajapinnan kautta (JSON-muodossa).\n",
          "@language": "fi"
        },
        {
          "@value": "Standard för att utbyta information om innehållet i ett\nIFC-dataset. Informationen kan utbytas i en ZIP-fil\n(XML-format) eller via ett API (JSON-format).\n",
          "@language": "sv"
        },
        {
          "@value": "Standard to exchange information about the contents inside\nan IFC dataset. Information can be exchanged in a ZIP file\n(XML) or through an API (JSON).\n",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "BCF:ää käytetään erityisesti tietomalliin liittyvien\nhavaintojen, kommenttien ja ongelmien välittämiseen eri\nBIM-ohjelmistojen välillä ilman, että itse tietomallia\ntarvitsee siirtää.\n",
          "@language": "fi"
        },
        {
          "@value": "BCF används särskilt för att förmedla observationer,\nkommentarer och problem kopplade till en informationsmodell\nmellan olika BIM-program utan att själva modellen behöver\növerföras.\n",
          "@language": "sv"
        },
        {
          "@value": "BCF is commonly used to communicate issues, comments and\nviewpoints related to a building information model without\nexchanging the model itself.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "buildingSMART Terminology",
          "@language": "en",
          "@id": "https://user.buildingsmart.org/knowledge-base/terminology/"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/tiedonsiirtostandardi"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/IFC",
        "https://teemualaluusua.github.io/sanasto1/tietomalli",
        "https://teemualaluusua.github.io/sanasto1/BIM"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/big-data",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "suurdata",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "stordata",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "big data",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "massadata",
          "@language": "fi",
          "termType": "Synonyymi"
        },
        {
          "@value": "suuraineisto",
          "@language": "fi",
          "termType": "Synonyymi"
        }
      ],
      "skos:definition": [
        {
          "@value": "Laajoja ja monimuotoisia tietokokonaisuuksia, joiden käsittely,\ntallentaminen ja analysointi edellyttävät skaalautuvaa teknologiaa.\n",
          "@language": "fi"
        },
        {
          "@value": "Stora och mångsidiga datamängder vars lagring, bearbetning och\nanalys kräver skalbar teknik.\n",
          "@language": "sv"
        },
        {
          "@value": "Large and diverse datasets whose storage, processing and\nanalysis require scalable technologies.\n",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Suurdataa kuvataan usein niin sanotulla 4V-mallilla:\nmäärä (volume), monimuotoisuus (variety), nopeus (velocity)\nja vaihtelevuus (variability). Data voi olla rakenteista,\npuolirakenteista tai rakenteetonta, kuten tekstiä, kuvia,\nvideoita tai ääntä.\n",
          "@language": "fi"
        },
        {
          "@value": "Stordata beskrivs ofta genom den så kallade 4V-modellen:\nvolym, variation, hastighet och variabilitet. Data kan vara\nstrukturerad, semistrukturerad eller ostrukturerad.\n",
          "@language": "sv"
        },
        {
          "@value": "Big data is often characterized by the 4V model:\nvolume, variety, velocity and variability. Data may be\nstructured, semi-structured or unstructured.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO/IEC 30105-9:2023",
          "@language": "en"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/data"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/data-analytiikka",
        "https://teemualaluusua.github.io/sanasto1/dataformaatti",
        "https://teemualaluusua.github.io/sanasto1/tekoäly"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/bom",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "tuoteosaluettelo",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "materiaalilista",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "bill of material",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "BOM",
          "@language": "fi",
          "termType": "Lyhenne"
        },
        {
          "@value": "BOM",
          "@language": "sv",
          "termType": "Lyhenne"
        },
        {
          "@value": "BOM",
          "@language": "en",
          "termType": "Lyhenne"
        }
      ],
      "skos:definition": [
        {
          "@value": "Luettelo kaikista osakokoonpanoista, osista ja/tai\nmateriaaleista, joita käytetään tuotteen valmistuksessa,\nmukaan lukien kunkin materiaalin määrä tuotteen\nvalmistamiseksi.\n",
          "@language": "fi"
        },
        {
          "@value": "Lista över alla delmonteringar, delar och/eller material\nsom används vid produktion av en produkt, inklusive den\nmängd av varje material som behövs för att tillverka\nprodukten.\n",
          "@language": "sv"
        },
        {
          "@value": "Listing of all the subassemblies, parts, and/or materials\nthat are used in the production of a product, including\nthe quantity of each material required to make a product.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO/TR 3151-1:2023(E)",
          "@language": "en"
        }
      ],
      "skos:narrower": [
        "https://teemualaluusua.github.io/sanasto1/ebom",
        "https://teemualaluusua.github.io/sanasto1/mbom"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/kokoonpano",
        "https://teemualaluusua.github.io/sanasto1/komponentti"
      ],
      "dcterms:created": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/bop",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "valmistusprosessiluettelo",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "processlista för tillverkning",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "bill of process",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "BOP",
          "@language": "fi",
          "termType": "Lyhenne"
        },
        {
          "@value": "BOP",
          "@language": "sv",
          "termType": "Lyhenne"
        },
        {
          "@value": "BOP",
          "@language": "en",
          "termType": "Lyhenne"
        }
      ],
      "skos:definition": [
        {
          "@value": "luettelo tuotteen valmistamiseen tarvittavista valmistusvaiheista ja prosesseista",
          "@language": "fi"
        },
        {
          "@value": "förteckning över de processer och arbetsmoment som krävs för att tillverka en produkt",
          "@language": "sv"
        },
        {
          "@value": "list of manufacturing processes and operations required to produce a product",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "BOP kuvaa tuotteen valmistusprosessin rakenteen ja täydentää usein BOM-luetteloa.",
          "@language": "fi"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO/TR 3151-1:2023",
          "@language": "en",
          "@id": "https://www.iso.org/"
        }
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/bom",
        "https://teemualaluusua.github.io/sanasto1/mom",
        "https://teemualaluusua.github.io/sanasto1/plm"
      ]
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/cde",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "yhteinen tietoympäristö",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "gemensam datamiljö",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "common data environment",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "CDE",
          "@language": "fi",
          "termType": "Lyhenne"
        },
        {
          "@value": "CDE",
          "@language": "sv",
          "termType": "Lyhenne"
        },
        {
          "@value": "CDE",
          "@language": "en",
          "termType": "Lyhenne"
        }
      ],
      "skos:definition": [
        {
          "@value": "Sovittu informaation lähde minkä tahansa projektin tai omaisuuskohteen\njokaisen informaatiokoosteen keräämiseksi, hallitsemiseksi ja\nlevittämiseksi hallinnoidun prosessin kautta.\n",
          "@language": "fi"
        },
        {
          "@value": "En överenskommen informationskälla för att samla in, hantera och\ndistribuera varje informationsmängd i ett projekt eller en tillgång\ngenom en kontrollerad process.\n",
          "@language": "sv"
        },
        {
          "@value": "Agreed source of information for collecting, managing and\ndisseminating each information container through a managed process\nfor a given project or asset.\n",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Yhteisen tietoympäristön työnkulku kuvaa käytettävät prosessit ja\nyhteisen tietoympäristön (CDE) sovellus voi tarjota näitä prosesseja\ntukevaa teknologiaa.\n",
          "@language": "fi"
        },
        {
          "@value": "Arbetsflödet i den gemensamma datamiljön beskriver de processer\nsom används och CDE-applikationen kan erbjuda teknik som stöder\ndessa processer.\n",
          "@language": "sv"
        },
        {
          "@value": "The workflow of the common data environment describes the processes\nused and the CDE application can provide technology supporting\nthose processes.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "EN ISO 19650-1:2018"
        },
        {
          "@value": "Suomi.fi terminologia – EN 19650",
          "@id": [
            "https://sanastot.suomi.fi/terminology/en19650/concept/concept-32"
          ]
        }
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/dataformaatti",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "dataformaatti",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "dataformat",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "data format",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "datan ennalta määritelty järjestys tallennusmedialla",
          "@language": "fi"
        },
        {
          "@value": "förutbestämd ordning av data på ett datamedium",
          "@language": "sv"
        },
        {
          "@value": "predetermined arrangement of data on a data medium",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Dataformaatti määrittelee, miten data esitetään ja\njäsennetään tallennuksessa tai tiedonsiirrossa.\n",
          "@language": "fi"
        },
        {
          "@value": "Dataformat anger hur data representeras och struktureras\nvid lagring eller överföring.\n",
          "@language": "sv"
        },
        {
          "@value": "A data format specifies how data is represented and\nstructured for storage or transmission.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO 5127:2022",
          "@language": "en"
        }
      ],
      "dcterms:created": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/dto",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "asiakasohjautuva tuotekehitys",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "kundstyrd produktutveckling",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "design to order",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "DTO",
          "@language": "fi",
          "termType": "Lyhenne"
        },
        {
          "@value": "DTO",
          "@language": "sv",
          "termType": "Lyhenne"
        },
        {
          "@value": "DTO",
          "@language": "en",
          "termType": "Lyhenne"
        }
      ],
      "skos:definition": [
        {
          "@value": "Tuotantotapa, jossa tuotteen suunnittelu, tuotekehitys ja\nvalmistus käynnistyvät asiakaskohtaisen tilauksen perusteella.\n",
          "@language": "fi"
        },
        {
          "@value": "Produktionssätt där produktens konstruktion, produktutveckling\noch tillverkning inleds utifrån en kundspecifik beställning.\n",
          "@language": "sv"
        },
        {
          "@value": "Production strategy in which product design, development\nand manufacturing are initiated based on a specific\ncustomer order.\n",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "DTO-tuotteet ovat asiakasräätälöityjä projektituotteita,\njotka suunnitellaan ja valmistetaan tilauskohtaisesti.\nToisin kuin ETO-tuotteissa, DTO-toimitus voi sisältää\nmerkittävää tuotekehitystä, mikä yleensä pidentää\ntoimitusaikoja.\n",
          "@language": "fi"
        },
        {
          "@value": "DTO-produkter är kundanpassade projektprodukter som\nkonstrueras och tillverkas baserat på en specifik order.\nTill skillnad från ETO-produkter kan DTO-leveranser\ninkludera omfattande produktutveckling, vilket ofta\nleder till längre leveranstider.\n",
          "@language": "sv"
        },
        {
          "@value": "DTO products are typically customized project products\ndesigned and manufactured for a specific order.\nDeliveries may include significant product development,\nwhich often results in longer lead times.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Alaluusua 2023",
          "@language": "fi",
          "@id": "https://aaltodoc.aalto.fi/server/api/core/bitstreams/d55ffacc-a2d7-414b-8f8c-313dff01e984/content"
        },
        {
          "@value": "Peltokorpi 2020",
          "@language": "fi",
          "@id": "https://www.aalto.fi/sites/default/files/2020-11/Loppuraportti_Tuotetiedon%20hallinta%20ja%20hyo%CC%88dynta%CC%88minen_2.11.2020_0.pdf"
        },
        {
          "@value": "ISO/TR 3151-1:2023",
          "@language": "en",
          "@id": "https://www.iso.org/"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/tuotantostrategia"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/ETO",
        "https://teemualaluusua.github.io/sanasto1/MTO",
        "https://teemualaluusua.github.io/sanasto1/ATO"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/ebom",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "suunnittelun tuoteosaluettelo",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "konstruktionsmateriallista",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "engineering bill of material",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "eBOM",
          "@language": "fi",
          "termType": "Lyhenne"
        },
        {
          "@value": "eBOM",
          "@language": "sv",
          "termType": "Lyhenne"
        },
        {
          "@value": "eBOM",
          "@language": "en",
          "termType": "Lyhenne"
        }
      ],
      "skos:definition": [
        {
          "@value": "Luettelo osanumeroista ja kokoonpanoista, jotka muodostavat\nsuunnittelun mukaisen tuotteen kokoonpanorakenteen ja\nsisältävät esimerkiksi raaka-aineen mitat ja\nmateriaalimääritykset.\n",
          "@language": "fi"
        },
        {
          "@value": "Lista över artikelnummer och sammansättningar som utgör\nden konstruktionsmässiga produktkonfigurationen och som\ninnehåller uppgifter om råmaterialets dimensioner och\nmaterialspecifikationer.\n",
          "@language": "sv"
        },
        {
          "@value": "List of part numbers and assemblies that make up the\ndesign engineering configuration that contains the raw\nstock size and the material specification.\n",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "English definition adapted from ISO 10303-240:2005.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO/TR 3151-1:2023(E)",
          "@language": "en"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/bom"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/mbom",
        "https://teemualaluusua.github.io/sanasto1/tuotteen suunnittelu"
      ],
      "dcterms:created": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
