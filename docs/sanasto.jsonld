    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/entiteetti",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "entiteetti",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "entitet",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "entity",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "jokin, joka voidaan tunnistaa yksikäsitteisesti",
          "@language": "fi"
        },
        {
          "@value": "något som kan identifieras entydigt",
          "@language": "sv"
        },
        {
          "@value": "something capable of being uniquely identified",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Entiteetit käsittävät aineelliset objektit, digitaaliset dokumentit,\nabstraktit kohteet (kuten ajat ja paikat), toimijat (luonnolliset ja\njuridiset henkilöt) sekä kaiken muun, mikä voidaan identifioida.\n",
          "@language": "fi"
        },
        {
          "@value": "Entiteter omfattar materiella objekt, digitala dokument,\nabstrakta företeelser (såsom tider och platser), aktörer\n(naturliga och juridiska personer) samt allt annat som kan\nidentifieras entydigt.\n",
          "@language": "sv"
        },
        {
          "@value": "Entities include material objects, electronic representations\nof content, abstract items (such as times and places), parties\n(human and corporate), as well as anything else that can be\nuniquely identified.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO 5127:2022",
          "@language": "en"
        }
      ],
      "dcterms:created": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/esitysformaatti",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "esitysformaatti",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "presentationsformat",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "presentation format",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "dataformaatti, jonka avulla digitaalinen data esitetään näyttöruudulla niin, että ihmiset pystyvät tulkitsemaan sitä",
          "@language": "fi"
        },
        {
          "@value": "dataformat som används för att presentera digital data på en skärm så att människor kan tolka informationen",
          "@language": "sv"
        },
        {
          "@value": "data format for the configuration of the display of digital data on the screen interface in a manner interpretable for human users",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Esitysformaatti määrittelee, miten digitaalinen tieto esitetään\nkäyttäjälle visuaalisessa käyttöliittymässä. Se voi sisältää esimerkiksi\ntekstin, taulukoiden, kuvien, karttojen tai muiden graafisten elementtien\nesitystavan. Esitysformaatti eroaa tallennusformaatista siinä, että se\nkeskittyy tiedon esittämiseen ihmiselle eikä sen tekniseen tallennukseen.\n",
          "@language": "fi"
        },
        {
          "@value": "Presentationsformat anger hur digital information visas för användaren\ni ett visuellt gränssnitt. Det kan omfatta till exempel hur text,\ntabeller, bilder, kartor eller andra grafiska element presenteras.\nPresentationsformat skiljer sig från lagringsformat genom att fokus\nligger på hur informationen presenteras för människor snarare än hur\nden lagras tekniskt.\n",
          "@language": "sv"
        },
        {
          "@value": "A presentation format defines how digital information is displayed to\nusers in a visual interface. It may include the presentation of text,\ntables, images, maps, or other graphical elements. A presentation\nformat differs from a storage format in that it focuses on how data is\npresented to humans rather than how it is technically stored.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO 5127:2022 Information and documentation — Foundation and vocabulary",
          "@language": "en"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/dataformaatti"
      ],
      "dcterms:created": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/eto",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "asiakasohjautuva tuotesuunnittelu",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "kundorderstyrd konstruktion",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "engineer-to-order",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "ETO",
          "@language": "fi",
          "termType": "Lyhenne"
        },
        {
          "@value": "ETO",
          "@language": "sv",
          "termType": "Lyhenne"
        },
        {
          "@value": "ETO",
          "@language": "en",
          "termType": "Lyhenne"
        }
      ],
      "skos:definition": [
        {
          "@value": "tuotantomenetelmä, jossa tuote suunnitellaan ja valmistetaan asiakaskohtaisen tilauksen perusteella",
          "@language": "fi"
        },
        {
          "@value": "produktionsmetod där produkten konstrueras och tillverkas utifrån en kundspecifik beställning",
          "@language": "sv"
        },
        {
          "@value": "production strategy in which a product is designed and manufactured based on a specific customer order",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "ETO-mallissa asiakastilauksen kytkentäpiste sijaitsee\ntuotesuunnitteluvaiheessa. Tuotteet ovat yleensä\nasiakaskohtaisesti kustomoituja, mikä johtaa\npidempiin toimitusaikoihin ja korkeampiin\ntuotantokustannuksiin.\n",
          "@language": "fi"
        },
        {
          "@value": "I ETO-modellen ligger kundorderpunkten i\nkonstruktionsfasen. Produkterna är vanligtvis\nkundanpassade, vilket ofta innebär längre\nleveranstider och högre produktionskostnader.\n",
          "@language": "sv"
        },
        {
          "@value": "In the ETO model the customer order decoupling\npoint occurs in the design phase. Products are\ntypically customised, which often results in\nlonger lead times and higher production costs.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Alaluusua, 2023",
          "@language": "fi",
          "@id": "https://aaltodoc.aalto.fi/server/api/core/bitstreams/d55ffacc-a2d7-414b-8f8c-313dff01e984/content"
        },
        {
          "@value": "Peltokorpi, 2020",
          "@language": "fi",
          "@id": "https://www.aalto.fi/sites/default/files/2020-11/Loppuraportti_Tuotetiedon%20hallinta%20ja%20hyo%CC%88dynta%CC%88minen_2.11.2020_0.pdf"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/tuotantomenetelmä"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/dto",
        "https://teemualaluusua.github.io/sanasto1/mto",
        "https://teemualaluusua.github.io/sanasto1/ato",
        "https://teemualaluusua.github.io/sanasto1/mto"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/fyysinen_tietomalli",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "fyysinen tietomalli",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "fysisk datamodell",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "physical data model",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "tietomalli, joka kuvaa tietojen tallentamisen teknisellä tasolla tietokantarakenteena",
          "@language": "fi"
        },
        {
          "@value": "datamodell som beskriver lagringen av data på teknisk nivå som en databasstruktur",
          "@language": "sv"
        },
        {
          "@value": "data model describing the storage of data at a technical level as a database structure",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Fyysinen tietomalli on loogisesta tietomallista\ntarkemmalle tasolle viety kuvaus, jossa otetaan\nkantaa tietokannan käytännön tekniseen toteutukseen\nvalitulla teknologialla.\n",
          "@language": "fi"
        },
        {
          "@value": "En fysisk datamodell är en mer detaljerad\nbeskrivning av en logisk datamodell där den\npraktiska tekniska implementeringen i en databas\nmed vald teknologi specificeras.\n",
          "@language": "sv"
        },
        {
          "@value": "A physical data model is a more detailed\nrepresentation of a logical data model specifying\nthe practical technical implementation in a\ndatabase using a chosen technology.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Suomi.fi-sanasto – RY-mallit",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/rymallit/c14"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/tietomalli"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/looginen tietomalli",
        "https://teemualaluusua.github.io/sanasto1/käsitemalli",
        "https://teemualaluusua.github.io/sanasto1/tietokanta"
      ],
      "dcterms:created": {
        "@value": "2025-12-23T14:08",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/informaatio",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "informaatio",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "information",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "information",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "datan uudelleen tulkittavissa oleva sovitun muotoinen esitystapa, joka sopii tiedonsiirtoon, viestintään, tulkintaan tai käsittelyyn",
          "@language": "fi"
        },
        {
          "@value": "överenskommen form av data som kan tolkas på nytt och som lämpar sig för överföring, kommunikation, tolkning eller behandling",
          "@language": "sv"
        },
        {
          "@value": "agreed form of data that can be reinterpreted and that is suitable for transmission, communication, interpretation or processing",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Informaatiota voi käsitellä ihminen tai sitä voidaan käsitellä automaattisin menetelmin.",
          "@language": "fi"
        },
        {
          "@value": "Information kan behandlas av människor eller automatiskt med tekniska metoder.",
          "@language": "sv"
        },
        {
          "@value": "Information may be processed by humans or automatically by technical means.",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Suomi.fi-sanasto – EN 19650 käsitteet",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/en19650/concept-17"
        },
        {
          "@value": "ISO 19650-1:2019"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/data"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/tieto",
        "https://teemualaluusua.github.io/sanasto1/tietomalli"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/informaatiomalli",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "informaatiomalli",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "informationsmodell",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "information model",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "tiettyä kohdetta kuvaava malli, jossa joukko tulkittavissa olevaa dataa on esitetty jäsennetyssä muodossa",
          "@language": "fi"
        },
        {
          "@value": "modell som beskriver ett visst objekt där en mängd tolkbar data presenteras i strukturerad form",
          "@language": "sv"
        },
        {
          "@value": "model describing a particular object in which a set of interpretable data is presented in a structured form",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Informaatiomalli on ihmisen tulkittavissa ja tietomallien mukaiselta osaltaan koneluettavassa muodossa.",
          "@language": "fi"
        },
        {
          "@value": "Informationsmodellen är tolkbar för människor och i den del som följer datamodeller även maskinläsbar.",
          "@language": "sv"
        },
        {
          "@value": "An information model is interpretable by humans and, where it follows data models, also machine-readable.",
          "@language": "en"
        },
        {
          "@value": "Informaatiomalli voi sisältää esimerkiksi geometrisia malleja,\nluetteloita, tietokantoja, kirjallisia dokumentteja, kuvia,\nvideoleikkeitä ja äänitteitä. Geometrisia malleja voidaan\nesittää 2- tai 3-ulotteisina ja niihin sisältyy usein sijaintitietoa.\n",
          "@language": "fi"
        },
        {
          "@value": "En informationsmodell kan innehålla till exempel geometriska modeller,\nlistor, databaser, skriftliga dokument, bilder, videoklipp och\nljudinspelningar. Geometriska modeller kan presenteras i två eller\ntre dimensioner och innehåller ofta positionsinformation.\n",
          "@language": "sv"
        },
        {
          "@value": "An information model may include, for example, geometric models,\nlists, databases, textual documents, images, video clips and\naudio recordings. Geometric models may be represented in two or\nthree dimensions and often include spatial information.\n",
          "@language": "en"
        },
        {
          "@value": "SFS-EN ISO 19650 -standardissa informaatiomalli-käsitteen\nmääritelmässä viitataan informaatiokoosteeseen, koska määritelmä\non laadittu mallin muodostamisen näkökulmasta. Informaatiokooste\non nimetty pysyvä joukko informaatiota, joka on noudettavissa\ntiedoston, järjestelmän tai sovelluksen tallennushierarkiasta.\n",
          "@language": "fi"
        },
        {
          "@value": "I standarden SFS-EN ISO 19650 hänvisar definitionen av\ninformationsmodell till ett informationssammanhang\n(information container), eftersom definitionen är formulerad\nur perspektivet att skapa en modell. Ett informationssammanhang\när en namngiven beständig uppsättning information som kan hämtas\nfrån ett fil-, system- eller applikationsbaserat lagringshierarki.\n",
          "@language": "sv"
        },
        {
          "@value": "In the SFS-EN ISO 19650 standard the definition of an\ninformation model refers to an information container,\nbecause the definition is formulated from the perspective\nof creating the model. An information container is a named\npersistent set of information retrievable from a file,\nsystem or application storage hierarchy.\n",
          "@language": "en"
        },
        {
          "@value": "Käsitejärjestelmäkaavio:\nhttps://sanastokeskus.fi/suomi.fi/rymallit/tietomalli.svg\n",
          "@language": "fi"
        },
        {
          "@value": "Begreppssystemdiagram:\nhttps://sanastokeskus.fi/suomi.fi/rymallit/tietomalli.svg\n",
          "@language": "sv"
        },
        {
          "@value": "Concept system diagram:\nhttps://sanastokeskus.fi/suomi.fi/rymallit/tietomalli.svg\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO 19650 – RY-mallit sanasto",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/rymallit/c15"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/tietomalli"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/informaatio",
        "https://teemualaluusua.github.io/sanasto1/tietomalli",
        "https://teemualaluusua.github.io/sanasto1/tietomallinnus"
      ],
      "dcterms:created": {
        "@value": "2025-12-23T14:08",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/informaatiomallinnus",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "informaatiomallinnus",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "informationsmodellering",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "information modeling",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "mallinnus, jonka tuloksena syntyy informaatiomalli",
          "@language": "fi"
        },
        {
          "@value": "modellering vars resultat är en informationsmodell",
          "@language": "sv"
        },
        {
          "@value": "modelling whose result is an information model",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Osa informaatiomallinnuksessa syntyvästä tiedosta on\nkoneluettavassa, tietomallien mukaisessa muodossa.\n",
          "@language": "fi"
        },
        {
          "@value": "En del av den information som skapas vid\ninformationsmodellering är maskinläsbar och\nföljer datamodeller.\n",
          "@language": "sv"
        },
        {
          "@value": "Part of the information produced in information\nmodelling is machine-readable and follows data models.\n",
          "@language": "en"
        },
        {
          "@value": "Käsitejärjestelmäkaavio:\nhttps://sanastokeskus.fi/suomi.fi/rymallit/tietomalli.svg\n",
          "@language": "fi"
        },
        {
          "@value": "Begreppssystemdiagram:\nhttps://sanastokeskus.fi/suomi.fi/rymallit/tietomalli.svg\n",
          "@language": "sv"
        },
        {
          "@value": "Concept system diagram:\nhttps://sanastokeskus.fi/suomi.fi/rymallit/tietomalli.svg\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Suomi.fi-sanasto – RY-mallit",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/rymallit/c4"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/mallinnus"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/informaatiomalli",
        "https://teemualaluusua.github.io/sanasto1/tietomalli",
        "https://teemualaluusua.github.io/sanasto1/tietomallinnus"
      ],
      "dcterms:created": {
        "@value": "2025-12-23T14:08",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/informaatiovaatimus",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "informaatiovaatimus",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "informationskrav",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "information requirement",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "vaatimus siitä, mitä tietoa tarvitaan, milloin ja missä muodossa se tuotetaan sekä kenelle se toimitetaan",
          "@language": "fi"
        },
        {
          "@value": "krav som anger vilken information som behövs, när och i vilken form den ska produceras samt till vem den ska levereras",
          "@language": "sv"
        },
        {
          "@value": "requirement specifying what information is needed, when it is to be produced, in what form and to whom it is to be delivered",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Sanastot.suomi.fi",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/en19650/concept-18"
        },
        {
          "@value": "EN ISO 19650-1:2018",
          "@language": "en",
          "@id": "https://www.iso.org"
        }
      ],
      "skos:narrower": [
        "https://teemualaluusua.github.io/sanasto1/organisaation informaatiovaatimus",
        "https://teemualaluusua.github.io/sanasto1/omaisuuden informaatiovaatimus",
        "https://teemualaluusua.github.io/sanasto1/projektin informaatiovaatimus",
        "https://teemualaluusua.github.io/sanasto1/vaiheen informaatiovaatimus",
        "https://teemualaluusua.github.io/sanasto1/tiedonvaihdon informaatiovaatimus"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/informaatiomalli",
        "https://teemualaluusua.github.io/sanasto1/tietomalli"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/iot",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "esineiden internet",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "sakernas internet",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "internet of things",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "IoT",
          "@language": "fi",
          "termType": "Lyhenne"
        },
        {
          "@value": "IoT",
          "@language": "sv",
          "termType": "Lyhenne"
        },
        {
          "@value": "IoT",
          "@language": "en",
          "termType": "Lyhenne"
        }
      ],
      "skos:definition": [
        {
          "@value": "Infrastruktuuri, joka koostuu toisiinsa yhdistetyistä\nentiteeteistä, kuten kohdeyksiköistä, ihmisistä,\njärjestelmistä ja informaatioresursseista, sekä\npalveluista, jotka käsittelevät fyysisestä ja\nvirtuaalimaailmasta tulevaa informaatiota ja\nreagoivat siihen.\n",
          "@language": "fi"
        },
        {
          "@value": "Infrastruktur som består av sammankopplade entiteter,\nsåsom enheter, människor, system och\ninformationsresurser, samt tjänster som behandlar\ninformation från den fysiska och virtuella världen\noch reagerar på den.\n",
          "@language": "sv"
        },
        {
          "@value": "Infrastructure consisting of interconnected entities\nsuch as devices, people, systems and information\nresources, together with services that process and\nrespond to information originating from the physical\nand virtual world.\n",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "IoT viittaa usein laitteiden ja koneiden\nyhdistämiseen internetiin sekä niiden tuottaman\ndatan hyödyntämiseen yhdessä muiden tietolähteiden\nkanssa.\n",
          "@language": "fi"
        },
        {
          "@value": "IoT avser ofta sammankoppling av maskiner och\nenheter till internet samt användning av data\nsom genereras av dessa tillsammans med andra\ndatakällor.\n",
          "@language": "sv"
        },
        {
          "@value": "IoT commonly refers to connecting devices and\nmachines to the internet and integrating the\ndata they generate with other data sources.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO/IEC 22989:2023",
          "@language": "en",
          "@id": "https://www.iso.org/standard/74296.html"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/verkko"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/anturi",
        "https://teemualaluusua.github.io/sanasto1/sulautettu järjestelmä",
        "https://teemualaluusua.github.io/sanasto1/big-data"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/iri",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "internationalized resource identifier",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "internationalized resource identifier",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "internationalized resource identifier",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "IRI",
          "@language": "fi",
          "termType": "Lyhenne"
        },
        {
          "@value": "IRI",
          "@language": "sv",
          "termType": "Lyhenne"
        },
        {
          "@value": "IRI",
          "@language": "en",
          "termType": "Lyhenne"
        }
      ],
      "skos:definition": [
        {
          "@value": "merkkijonosta muodostuva tunnus, joka yksikäsitteisesti yksilöi tietyn verkkoresurssin noudattaen sovittua syntaksia ja kattaa URI-tunnusta laajemman merkkivalikoiman",
          "@language": "fi"
        },
        {
          "@value": "a global identifier in the context of the World Wide Web which builds on the Uniform Resource Identifier (URI) protocol by expanding the set of permitted characters",
          "@language": "en"
        },
        {
          "@value": "en global identifierare i World Wide Web som bygger på URI-protokollet (Uniform Resource Identifier) genom att utöka uppsättningen tillåtna tecken",
          "@language": "sv"
        }
      ],
      "skos:note": [
        {
          "@value": "IRI-tunnistetta käytetään tyypillisesti World Wide Webin verkkoresurssien yksilöimisessä.",
          "@language": "fi"
        },
        {
          "@value": "IRI-identifierare används typiskt för att identifiera webbresurser på World Wide Web.",
          "@language": "sv"
        },
        {
          "@value": "A string of characters that unambiguously identifies a particular resource. To guarantee uniformity, all IRIs follow a predefined set of syntax rules, but also maintain extensibility through a separately defined hierarchical naming scheme.",
          "@language": "en"
        },
        {
          "@value": "While URIs are limited to a subset of the US-ASCII character set, IRIs may additionally contain most characters from the Universal Character Set, including Chinese, Japanese, Korean, and Cyrillic characters.",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Yhteentoimivuusalustan sanasto",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/yti/concept-98"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/URI"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/linkitetty data",
        "https://teemualaluusua.github.io/sanasto1/RDF",
        "https://teemualaluusua.github.io/sanasto1/nimiavaruus"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-17T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/kaavatietomalli",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "kaavatietomalli",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "plandatamodell",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "data model for land use plans",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "tietomalli, joka on tarkoitettu kaavan tietojen kuvaamiseen",
          "@language": "fi"
        },
        {
          "@value": "datamodell som är avsedd för att beskriva information i en plan",
          "@language": "sv"
        },
        {
          "@value": "data model intended for describing the information of a land use plan",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Valtakunnallinen kaavatietomalli koostuu kaavaa,\nkaavakohteita ja kaavamääräyksiä kuvaavista osista.\n",
          "@language": "fi"
        },
        {
          "@value": "Den nationella plandatamodellen består av delar\nsom beskriver planen, planobjekt och planbestämmelser.\n",
          "@language": "sv"
        },
        {
          "@value": "The national data model for land use plans consists\nof parts describing the plan, plan objects and\nplanning regulations.\n",
          "@language": "en"
        },
        {
          "@value": "Käsitejärjestelmäkaavio:\nhttps://sanastokeskus.fi/suomi.fi/rymallit/tietomalli.svg\n",
          "@language": "fi"
        },
        {
          "@value": "Begreppssystemdiagram:\nhttps://sanastokeskus.fi/suomi.fi/rymallit/tietomalli.svg\n",
          "@language": "sv"
        },
        {
          "@value": "Concept system diagram:\nhttps://sanastokeskus.fi/suomi.fi/rymallit/tietomalli.svg\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Suomi.fi-sanasto – RY-mallit",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/rymallit/c10"
        },
        {
          "@value": "Rakennetun ympäristön sanasto",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/rakymp/c782"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/tietomalli"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/kaava",
        "https://teemualaluusua.github.io/sanasto1/kaavamääräys",
        "https://teemualaluusua.github.io/sanasto1/kaavakohde"
      ],
      "dcterms:created": {
        "@value": "2025-12-23T14:08",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/käsitemalli",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "käsitemalli",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "begreppsmodell",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "conceptual schema",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "Tietomalli, joka määrittelee kohdealueen käsitteet\nja niiden väliset suhteet.\n",
          "@language": "fi"
        },
        {
          "@value": "Informationsmodell som definierar begreppen\ni ett visst verksamhetsområde och relationerna\nmellan dem.\n",
          "@language": "sv"
        },
        {
          "@value": "Model that defines the concepts of a universe\nof discourse and the relationships between them.\n",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Käsitemalli kuvaa kohdealueen keskeiset käsitteet\nja niiden väliset suhteet riippumatta\ntietojärjestelmien teknisestä toteutuksesta.\n",
          "@language": "fi"
        },
        {
          "@value": "En begreppsmodell beskriver centrala begrepp i ett\nverksamhetsområde och relationerna mellan dem\noberoende av teknisk implementation.\n",
          "@language": "sv"
        },
        {
          "@value": "A conceptual schema describes the core concepts\nof a domain and the relationships between them\nindependent of technical implementation.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO 5127:2022",
          "@language": "en",
          "@id": "https://www.iso.org"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/tietomalli"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/ontologia",
        "https://teemualaluusua.github.io/sanasto1/skeema",
        "https://teemualaluusua.github.io/sanasto1/tietomalli"
      ],
      "dcterms:created": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/käsiteskeema",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "käsiteskeema",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "begreppsschema",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "conceptual schema",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "Käsitemallin muodollinen kuvailu, joka esittää\nkohdealueen käsitteet, niiden ominaisuudet ja\nsuhteet rakenteisessa muodossa.\n",
          "@language": "fi"
        },
        {
          "@value": "Formell beskrivning av en begreppsmodell som\nanger begrepp i ett visst område samt deras\negenskaper och relationer i strukturerad form.\n",
          "@language": "sv"
        },
        {
          "@value": "Formal description of a conceptual model that\nspecifies the concepts of a domain together\nwith their properties and relationships.\n",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Käsiteskeema esittää käsitemallin muodollisessa\nmuodossa ja sitä voidaan käyttää tietomallien\nsuunnittelun ja tietojärjestelmien kehittämisen\nlähtökohtana.\n",
          "@language": "fi"
        },
        {
          "@value": "Ett begreppsschema uttrycker en begreppsmodell\ni formell form och används ofta som grund för\nutveckling av informationsmodeller och\ninformationssystem.\n",
          "@language": "sv"
        },
        {
          "@value": "A conceptual schema expresses a conceptual model\nin a formalized structure and can serve as a basis\nfor designing information models and information\nsystems.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO 5127:2022",
          "@language": "en",
          "@id": "https://www.iso.org/standard/59743.html"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/käsitemalli"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/tietomalli",
        "https://teemualaluusua.github.io/sanasto1/ontologia",
        "https://teemualaluusua.github.io/sanasto1/skeema"
      ],
      "dcterms:created": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/koodisto",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "koodisto",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "kodlista",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "codelist",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "kokoelma tiettyä käyttötarkoitusta varten määriteltyjä koodeja tai luettelo luokan ominaisuuden sallituista arvoista",
          "@language": "fi"
        },
        {
          "@value": "Value domain including a code for each permissible value / Complete set of data element values of a coded simple data element",
          "@language": "en"
        },
        {
          "@value": "värdemängd som innehåller en kod för varje tillåtet värde / fullständig uppsättning värden för ett kodat dataelement",
          "@language": "sv"
        }
      ],
      "skos:note": [
        {
          "@value": "Koodisto määrittelee sallitut arvot tietylle tietoelementille ja toimii\ntiedon validoinnin ja yhdenmukaisuuden varmistamisen välineenä.\n",
          "@language": "fi"
        },
        {
          "@value": "En kodlista definierar tillåtna värden för ett visst dataelement och fungerar\nsom ett medel för att säkerställa datavalidering och enhetlighet.\n",
          "@language": "sv"
        },
        {
          "@value": "A codelist defines the permissible values for a specific data element and\nserves as a means to ensure data validation and consistency.\n",
          "@language": "en"
        },
        {
          "@value": "Koodistoja käytetään erityisesti tietomalleissa ja rajapinnoissa, joissa\ntietosisältö esitetään ennalta määriteltyjen arvojen avulla.\n",
          "@language": "fi"
        },
        {
          "@value": "Kodlistor används särskilt i datamodeller och gränssnitt där informationsinnehåll\nrepresenteras med hjälp av fördefinierade värden.\n",
          "@language": "sv"
        },
        {
          "@value": "Codelists are particularly used in data models and interfaces where\ninformation content is represented using predefined values.\n",
          "@language": "en"
        },
        {
          "@value": "Koodisto eroaa luokituksesta siten, että koodisto määrittelee sallitut arvot,\nkun taas luokitus kuvaa käsitteellistä ryhmittelyä.\n",
          "@language": "fi"
        },
        {
          "@value": "En kodlista skiljer sig från en klassificering genom att den definierar\ntillåtna värden, medan en klassificering beskriver en begreppsmässig\nindelning.\n",
          "@language": "sv"
        },
        {
          "@value": "A codelist differs from a classification in that it defines permissible\nvalues, whereas a classification describes a conceptual grouping.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Yhteentoimivuusalustan sanasto",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/yti/concept-11"
        },
        {
          "@value": "ISO 19136",
          "@language": "en",
          "@id": "https://www.iso.org/"
        },
        {
          "@value": "ISO 9735-1:2002",
          "@language": "en",
          "@id": "https://www.iso.org/"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/tietomääritys"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/luokitus",
        "https://teemualaluusua.github.io/sanasto1/sanasto",
        "https://teemualaluusua.github.io/sanasto1/tietomalli",
        "https://teemualaluusua.github.io/sanasto1/metatieto"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-17T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/käsitteellinen-tietomalli",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "käsitteellinen tietomalli",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "konceptuell datamodell",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "conceptual model",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "käsitemalli",
          "@language": "fi",
          "termType": "Synonyymi"
        }
      ],
      "skos:definition": [
        {
          "@value": "tietomalli, joka kuvaa tarkastelun kohteena olevat kohdemaailman käsitteet ja niiden väliset suhteet",
          "@language": "fi"
        },
        {
          "@value": "Model that defines concepts of a universe of discourse",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Yhteentoimivuusalustan sanasto",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/yti/concept-65"
        },
        {
          "@value": "ISO 19101",
          "@language": "en",
          "@id": "https://www.iso.org/"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/tietomalli"
      ],
      "skos:narrower": [
