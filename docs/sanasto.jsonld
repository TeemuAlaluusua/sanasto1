    {
      "@id": "https://teemualaluusua.github.io/sanasto1/rakentamisen-tieto-ja-informaatiomallit",
      "@type": "skos:ConceptScheme",
      "skos:prefLabel": [
        {
          "@value": "rakentamisen-tieto-ja-informaatiomallit",
          "@language": "fi"
        }
      ]
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/alavirta",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/rakentamisen-tieto-ja-informaatiomallit",
      "skos:prefLabel": [
        {
          "@value": "alavirta",
          "@language": "fi"
        },
        {
          "@value": "nedströms",
          "@language": "sv"
        },
        {
          "@value": "downstream",
          "@language": "en"
        }
      ],
      "skos:definition": [
        {
          "@value": "Toimitusketjun osa, joka kattaa vaiheet ja toimijat raaka-ainetoimittajista kokoonpanevaan tai tuottavaan yksikköön. Vastakohta ylävirralle. Käytetään myös nimitystä jakelumarkkinat.",
          "@language": "fi"
        }
      ],
      "skos:note": [
        {
          "@value": "Termiä käytetään toimitusketjun tarkastelussa kuvaamaan virtausta kohti\nkokoonpanoa tai tuotantoa. Rakentamisen kontekstissa alavirta voi tarkoittaa\nesimerkiksi materiaalien ja komponenttien toimitusketjua työmaalle tai\nelementtitehtaalle.\n",
          "@language": "fi"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Logistiikan maailma -termisanasto (2025)",
          "@id": "https://www.logistiikanmaailma.fi/aineistot/sanastot/logistiikan-maailma-termisanasto/"
        }
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/ylävirta"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-02-26T10:15:35",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/alfanumeerinen",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/rakentamisen-tieto-ja-informaatiomallit",
      "skos:prefLabel": [
        {
          "@value": "alfanumeerinen",
          "@language": "fi"
        },
        {
          "@value": "alfanumerisk",
          "@language": "sv"
        },
        {
          "@value": "alphanumeric",
          "@language": "en"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "aakkosnumeerinen",
          "@language": "fi"
        }
      ],
      "skos:definition": [
        {
          "@value": "Aakkosista (A–Z) ja numeroista (0–9) koostuva tai niitä sisältävä merkistö, koodi tai tieto. Vastakohtana pelkästään aakkosellinen tai pelkästään numeerinen.\n",
          "@language": "fi"
        }
      ],
      "skos:note": [
        {
          "@value": "Alfanumeerinen ei sisällä välimerkkejä tai erikoismerkkejä; jos myös niitä sallitaan, puhutaan esimerkiksi alfanumeerisesta ja erikoismerkkejä sisältävästä merkkijonosta tai laajennetusta merkistöstä.",
          "@language": "fi"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO/IEC 19762:2025 Information technology — Automatic identification and data capture techniques — Harmonized vocabulary"
        }
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-02-26T10:33:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/alkuperäisformaatti",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/rakentamisen-tieto-ja-informaatiomallit",
      "skos:prefLabel": [
        {
          "@value": "alkuperäisformaatti",
          "@language": "fi"
        },
        {
          "@value": "nativt format",
          "@language": "sv"
        },
        {
          "@value": "Native format",
          "@language": "en"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "natiiviformaatti",
          "@language": "fi"
        },
        {
          "@value": "natiivimalli",
          "@language": "fi"
        },
        {
          "@value": "ursprungsformat",
          "@language": "sv"
        },
        {
          "@value": "nativt filformat",
          "@language": "sv"
        },
        {
          "@value": "native file format",
          "@language": "en"
        },
        {
          "@value": "proprietary format",
          "@language": "en"
        }
      ],
      "skos:definition": [
        {
          "@value": "Mallinnusohjelman oma tallennusformaatti. Rakennusalan julkaisuissa käytetään\ntälle synonyyminä käsitteitä natiivimalli tai natiiviformaatti.\n",
          "@language": "fi"
        },
        {
          "@value": "Det filformat som är specifikt för ett visst modelleringsprogram och dess\ninterna lagring av modellen. Inom byggbranschen används även benämningarna\nnativ modell eller nativt format som synonymer.\n",
          "@language": "sv"
        },
        {
          "@value": "The file format specific to a particular modelling software used for the\nmodel’s native storage. In the construction industry, the terms native model\nor native format are also used as synonyms.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "BEC:2023 Elementtisuunnittelun mallinnusohje",
          "@language": "fi",
          "@id": "https://www.elementtisuunnittelu.fi/Download/23982/BEC2012%20Elementtisuunnittelun%20mallinnusohje_v110.pdf"
        },
        {
          "@value": "YTV:2012 Yleiset tietomallivaatimukset",
          "@language": "fi",
          "@id": "https://wiki.buildingsmart.fi/fi/04_Julkaisut_ja_Standardit/YTV"
        }
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/natiiviformaatti",
        "https://teemualaluusua.github.io/sanasto1/natiivimalli"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-02-27T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/anturi",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/rakentamisen-tieto-ja-informaatiomallit",
      "skos:prefLabel": [
        {
          "@value": "anturi",
          "@language": "fi"
        },
        {
          "@value": "sensor",
          "@language": "sv"
        },
        {
          "@value": "sensor",
          "@language": "en"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "sensori",
          "@language": "fi"
        },
        {
          "@value": "givare",
          "@language": "sv"
        },
        {
          "@value": "transducer",
          "@language": "en"
        }
      ],
      "skos:definition": [
        {
          "@value": "Anturi on laite, joka reagoi fyysiseen ärsykkeeseen kuten lämpöön, valoon,\nääneen, paineeseen, vetovoimaan tai liikkeeseen ja välittää sen arvon eteenpäin.\nAntureita hyödynnetään esimerkiksi erilaisissa IoT-ratkaisuissa.\n",
          "@language": "fi"
        },
        {
          "@value": "En sensor är en anordning som reagerar på en fysisk påverkan såsom värme, ljus,\nljud, tryck, gravitation eller rörelse och vidarebefordrar dess värde.\nSensorer används till exempel i olika IoT-lösningar.\n",
          "@language": "sv"
        },
        {
          "@value": "A sensor is a device that responds to a physical stimulus such as heat, light,\nsound, pressure, gravity or motion and transmits its value onward. Sensors are\nused, for example, in various IoT solutions.\n",
          "@language": "en"
        }
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-02-27T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/arvoketju",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/rakentamisen-tieto-ja-informaatiomallit",
      "skos:prefLabel": [
        {
          "@value": "arvoketju",
          "@language": "fi"
        },
        {
          "@value": "värdekedja",
          "@language": "sv"
        },
        {
          "@value": "value chain",
          "@language": "en"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "arvoverkko",
          "@language": "fi"
        },
        {
          "@value": "värdenätverk",
          "@language": "sv"
        },
        {
          "@value": "value network",
          "@language": "en"
        }
      ],
      "skos:definition": [
        {
          "@value": "Arvoketju (engl. value chain) tarkoittaa tuotteen tai palvelun vaiheittaista\njalostumista valmiiksi tuotteeksi tai palveluksi siten, että jokainen vaihe\nlisää lopputuotteen tai -palvelun arvoa.\n",
          "@language": "fi"
        },
        {
          "@value": "En värdekedja avser den stegvisa förädlingen av en produkt eller tjänst till en\nfärdig produkt eller tjänst, där varje steg ökar slutproduktens eller\nslutresultatets värde.\n",
          "@language": "sv"
        },
        {
          "@value": "A value chain refers to the stepwise transformation of a product or service\ninto a finished offering, where each stage adds value to the final product or\nservice.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO/PAS 24644-1:2023",
          "@language": "en",
          "@id": "https://standards.globalspec.com/std/14629302/pas-24644-1"
        }
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/toimitusketju",
        "https://teemualaluusua.github.io/sanasto1/liiketoimintaprosessi"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-02-27T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/asiakastilauksen-kytkeytymiskohta",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/rakentamisen-tieto-ja-informaatiomallit",
      "skos:prefLabel": [
        {
          "@value": "asiakastilauksen kytkeytymiskohta",
          "@language": "fi"
        },
        {
          "@value": "kundorderpunkt",
          "@language": "sv"
        },
        {
          "@value": "customer order decoupling point",
          "@language": "en"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "tilauskytkentäpiste",
          "@language": "fi"
        },
        {
          "@value": "tilauksen kytkeytymispiste",
          "@language": "fi"
        },
        {
          "@value": "kundorderkopplingspunkt",
          "@language": "sv"
        },
        {
          "@value": "order penetration point",
          "@language": "en"
        }
      ],
      "skos:definition": [
        {
          "@value": "Se toimitusketjun kohta, jossa tuote tai palvelu liitetään asiakkaan tekemään\ntilaukseen ja jossa toiminta muuttuu ennusteohjautuvasta tilausohjautuvaksi.\n",
          "@language": "fi"
        },
        {
          "@value": "Den punkt i leveranskedjan där en produkt eller tjänst kopplas till en kundorder\noch där styrningen övergår från prognosbaserad till orderstyrd.\n",
          "@language": "sv"
        },
        {
          "@value": "The point in the supply chain where a product or service is linked to a specific\ncustomer order and operations shift from forecast-driven to order-driven.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Logistiikan maailma -termisanasto:2025",
          "@language": "fi",
          "@id": "https://www.logistiikanmaailma.fi/aineistot/sanastot/logistiikan-maailma-termisanasto/"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/toimitusketju"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/arvoketju",
        "https://teemualaluusua.github.io/sanasto1/tilausohjautuva tuotanto",
        "https://teemualaluusua.github.io/sanasto1/ennusteohjautuva tuotanto"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-02-27T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/ato",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/rakentamisen-tieto-ja-informaatiomallit",
      "skos:prefLabel": [
        {
          "@value": "ATO",
          "@language": "fi"
        },
        {
          "@value": "ATO",
          "@language": "sv"
        },
        {
          "@value": "Assembly-to-order",
          "@language": "en"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "asiakasohjautuva kokoonpano",
          "@language": "fi"
        },
        {
          "@value": "kundorderstyrd montering",
          "@language": "sv"
        },
        {
          "@value": "ATO",
          "@language": "en"
        }
      ],
      "skos:definition": [
        {
          "@value": "Asiakasohjautuva kokoonpanolla tarkoitetaan tuotanto- ja toimitusstrategiaa, jossa tuote kootaan asiakkaan\ntilauksen jälkeen varastoiduista vakiokomponenteista tai\nosakokoonpanoista. Strategia yhdistää massatuotannon\ntehokkuuden ja asiakaskohtaisen konfiguroinnin joustavuuden.\nToimitusaika määräytyy komponentti- ja osakokoonpanovaraston\nsaatavuuden sekä kokoonpanoajan perusteella.\n",
          "@language": "fi"
        },
        {
          "@value": "Kundorderstyrd montering är en produktions- och leveransstrategi där produkten monteras efter\nkundorder från lagerhållna standardkomponenter eller delmontage.\nStrategin kombinerar effektiviteten i massproduktion med\nflexibiliteten i kundanpassad konfiguration. Leveranstiden beror\npå tillgången på komponent- och delmontagelager samt monteringstid.\n",
          "@language": "sv"
        },
        {
          "@value": "Assembly-to-order (ATO) is a production and fulfilment strategy in\nwhich a product is assembled after receipt of a customer order\nfrom stocked standard components or subassemblies. The approach\ncombines the efficiency of mass production with the flexibility of\ncustomer-specific configuration. Lead time depends on the\navailability of components and subassemblies and the assembly time.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Alaluusua 2023",
          "@language": "fi",
          "@id": "https://aaltodoc.aalto.fi/server/api/core/bitstreams/d55ffacc-a2d7-414b-8f8c-313dff01e984/content"
        },
        {
          "@value": "Peltokorpi 2020 Tuotetiedon hallinta ja hyödyntäminen",
          "@language": "fi",
          "@id": "https://www.aalto.fi/sites/default/files/2020-11/Loppuraportti_Tuotetiedon%20hallinta%20ja%20hyo%CC%88dynta%CC%88minen_2.11.2020_0.pdf"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/tuotanto-ja-toimitusstrategia"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/asiakastilauksen-kytkeytymiskohta",
        "https://teemualaluusua.github.io/sanasto1/mto",
        "https://teemualaluusua.github.io/sanasto1/mts",
        "https://teemualaluusua.github.io/sanasto1/eto"
      ],
