        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/metatietoskeema",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "metatietoskeema",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "metadataschema",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "metadata schema",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "looginen kaavio, joka osoittaa metatiedon elementtien väliset suhteet",
          "@language": "fi"
        },
        {
          "@value": "logiskt schema som visar relationerna mellan metadataelement",
          "@language": "sv"
        },
        {
          "@value": "logical plan showing the relationships between metadata elements",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Metatietoskeema määrittelee metatiedon elementit,\nniiden merkitykset ja rakenteen, ja sitä käytetään\nmetatiedon järjestämiseen ja yhteentoimivuuden\ntukemiseen tietojärjestelmissä.\n",
          "@language": "fi"
        },
        {
          "@value": "Ett metadataschema anger metadataelementen,\nderas betydelse och struktur och används för\natt organisera metadata och stödja\ninteroperabilitet mellan informationssystem.\n",
          "@language": "sv"
        },
        {
          "@value": "A metadata schema specifies metadata elements,\ntheir meaning and structure, and supports\norganization and interoperability of metadata\nin information systems.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO 5127:2022",
          "@language": "en",
          "@id": "https://www.iso.org"
        }
      ],
      "dcterms:created": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/mom",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "tuotannon operatiivinen hallinta",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "operativ produktionsstyrning",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "manufacturing operations management",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "MOM",
          "@language": "fi",
          "termType": "Lyhenne"
        },
        {
          "@value": "MOM",
          "@language": "sv",
          "termType": "Lyhenne"
        },
        {
          "@value": "MOM",
          "@language": "en",
          "termType": "Lyhenne"
        }
      ],
      "skos:definition": [
        {
          "@value": "tuotannon operatiivisten toimintojen hallintaa tukeva järjestelmien ja prosessien kokonaisuus",
          "@language": "fi"
        },
        {
          "@value": "helhet av system och processer för styrning och hantering av operativa produktionsaktiviteter",
          "@language": "sv"
        },
        {
          "@value": "set of systems and processes used to manage and control manufacturing operations",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "MOM yhdistää tuotannon suunnittelun, toteutuksen, seurannan ja analysoinnin tuotantoympäristössä.",
          "@language": "fi"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO/TR 3151-1:2023",
          "@language": "en",
          "@id": "https://www.iso.org/"
        }
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/plm",
        "https://teemualaluusua.github.io/sanasto1/mes"
      ]
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/nimiavaruus",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "nimiavaruus",
          "@language": "fi",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "namnrymd",
          "@language": "sv",
          "termType": "Synonyymi"
        },
        {
          "@value": "namespace",
          "@language": "en",
          "termType": "Synonyymi"
        }
      ],
      "skos:definition": [
        {
          "@value": "nimeämiseen tietyssä asia- tai toimintayhteydessä käytettävissä olevien elementtien joukko",
          "@language": "fi"
        },
        {
          "@value": "mängd av element som används för namngivning inom ett visst sak- eller verksamhetssammanhang",
          "@language": "sv"
        },
        {
          "@value": "set of elements available for naming within a specific context or domain of activity",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Elementit voivat olla esimerkiksi nimiä, sanoja tai teknisiä termejä.",
          "@language": "fi"
        },
        {
          "@value": "Yhden nimiavaruuden sisällä yhdellä nimellä saa olla vain yksi merkitys, mutta eri nimiavaruuksissa samaa nimeä voi käyttää eri merkityksissä.",
          "@language": "fi"
        },
        {
          "@value": "Elementen kan till exempel vara namn, ord eller tekniska termer.",
          "@language": "sv"
        },
        {
          "@value": "Inom en och samma namnrymd får ett namn endast ha en betydelse, men i olika namnrymder kan samma namn användas med olika betydelser.",
          "@language": "sv"
        },
        {
          "@value": "Elements can be, for example, names, words or technical terms.",
          "@language": "en"
        },
        {
          "@value": "Within a single namespace, a name can have only one meaning, but in different namespaces the same name can be used with different meanings.",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Yhteentoimivuusalustan sanasto",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/yti/concept-30"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/tietomääritys"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/tunniste",
        "https://teemualaluusua.github.io/sanasto1/URI",
        "https://teemualaluusua.github.io/sanasto1/ontologia",
        "https://teemualaluusua.github.io/sanasto1/skeema"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-17T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/OCR",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "optinen merkkien tunnistus",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "optisk teckenigenkänning",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "optical character recognition",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "optinen merkinluku",
          "@language": "fi",
          "termType": "Synonyymi"
        },
        {
          "@value": "tekstintunnistus",
          "@language": "fi",
          "termType": "Synonyymi"
        },
        {
          "@value": "optisk teckenläsning",
          "@language": "sv",
          "termType": "Synonyymi"
        },
        {
          "@value": "OCR",
          "@language": "en",
          "termType": "Lyhenne"
        }
      ],
      "skos:definition": [
        {
          "@value": "Menetelmä, jossa koneellisesti kirjoitettua, tulostettua tai\nkäsin kirjoitettua tekstiä sisältävät kuvat muunnetaan\nkoneellisesti käsiteltäväksi tekstimuodoksi.\n",
          "@language": "fi"
        },
        {
          "@value": "Metod där bilder som innehåller maskinskriven, tryckt eller\nhandskriven text omvandlas till maskinläsbar text.\n",
          "@language": "sv"
        },
        {
          "@value": "Conversion of images of typed, printed or handwritten text\ninto machine-readable text.\n",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "OCR-teknologiaa käytetään esimerkiksi skannattujen asiakirjojen\ndigitoinnissa, arkistoinnissa ja tekstin automaattisessa\nkäsittelyssä.\n",
          "@language": "fi"
        },
        {
          "@value": "OCR-teknik används till exempel för digitalisering av skannade\ndokument, arkivering och automatisk behandling av text.\n",
          "@language": "sv"
        },
        {
          "@value": "OCR technology is commonly used for digitizing scanned\ndocuments and enabling automated processing of textual\ninformation.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO/IEC 22989:2023",
          "@language": "en",
          "@id": "https://www.iso.org/standard/74296.html"
        }
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/kuvankäsittely",
        "https://teemualaluusua.github.io/sanasto1/dokumenttien digitointi"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/oikeudellinen-yhteentoimivuus",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "oikeudellinen yhteentoimivuus",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "rättslig interoperabilitet",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "legal interoperability",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "yhteentoimivuus, joka mahdollistaa tiedonsiirrot eri lainsäädännöllisten alueiden välillä ilman, että asiaankuuluvaa lainsäädäntöä rikotaan",
          "@language": "fi"
        },
        {
          "@value": "interoperabilitet som gör det möjligt att överföra information mellan områden med olika lagstiftning utan att relevanta lagar bryts",
          "@language": "sv"
        },
        {
          "@value": "form of interoperability that enables data transfers between different legislative regions without violating any pertinent legislation",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Oikeudellinen yhteentoimivuus liittyy erityisesti tietojärjestelmissä käsiteltävien tietojen luonteeseen ja tapoihin, joilla tietoja kerätään, järjestetään ja siirretään.",
          "@language": "fi"
        },
        {
          "@value": "Rättslig interoperabilitet anknyter speciellt till information i informationssystem samt till informationens art och hur man samlar in, ordnar och överför informationen.",
          "@language": "sv"
        },
        {
          "@value": "Legal interoperability is connected especially to the nature of the data that is contained in the information systems and how this data is collected, arranged and transferred.",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Yhteentoimivuusalustan sanasto",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/yti/concept-71"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/yhteentoimivuus"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/tekninen yhteentoimivuus",
        "https://teemualaluusua.github.io/sanasto1/semanttinen yhteentoimivuus",
        "https://teemualaluusua.github.io/sanasto1/organisatorinen yhteentoimivuus"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-17T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/air",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "omaisuuskohteen informaatiovaatimukset",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "informationskrav för tillgång",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "asset information requirements",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "AIR",
          "@language": "fi",
          "termType": "Lyhenne"
        },
        {
          "@value": "AIR",
          "@language": "sv",
          "termType": "Lyhenne"
        },
        {
          "@value": "AIR",
          "@language": "en",
          "termType": "Lyhenne"
        }
      ],
      "skos:definition": [
        {
          "@value": "Omaisuuskohteen informaatiovaatimukset kuvaavat informaatiovaatimukset suhteessa omaisuuskohteen käyttöön. Omaisuuskohteen informaatiovaatimuksissa (AIR) esitetään omaisuuskohteen informaation tuottamiseen tarvittavat liikkeenjohdolliset, kaupalliset ja tekniset näkökohdat.",
          "@language": "fi"
        },
        {
          "@value": "Informationskrav för en tillgång beskriver informationskraven i förhållande till användningen av tillgången. I tillgångens informationskrav (AIR) anges de ledningsmässiga, kommersiella och tekniska aspekter som behövs för att producera information om tillgången.",
          "@language": "sv"
        },
        {
          "@value": "Asset information requirements describe the information requirements in relation to the use of an asset. The asset information requirements (AIR) present the managerial, commercial and technical aspects required to produce information about the asset.",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "EN/ISO 19650:2018",
          "@language": "fi",
          "@id": "https://www.iso.org/standard/68078.html"
        },
        {
          "@value": "Suomi.fi-sanasto EN 19650",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/en19650/concept-20"
        }
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/omaisuuskohteen-informaatiomalli",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "omaisuuskohteen informaatiomalli",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "tillgångsinformationsmodell",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "asset information model",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "AIM",
          "@language": "fi",
          "termType": "Lyhenne"
        },
        {
          "@value": "AIM",
          "@language": "sv",
          "termType": "Lyhenne"
        },
        {
          "@value": "AIM",
          "@language": "en",
          "termType": "Lyhenne"
        }
      ],
      "skos:definition": [
        {
          "@value": "rakennuskohteen informaatiomalli, joka sisältää rakennuskohteen käyttö- ja ylläpitovaiheen aikana tarvittavat tiedot",
          "@language": "fi"
        },
        {
          "@value": "informationsmodell för byggnadsobjekt som innehåller de uppgifter som behövs under byggnadsobjektets användnings- och underhållsskede",
          "@language": "sv"
        },
        {
          "@value": "information model of a built asset that contains the information required during the use and maintenance phase of the built asset",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Käsitejärjestelmäkaavio: https://sanastokeskus.fi/suomi.fi/rymallit/tietomalli.svg",
          "@language": "fi"
        },
        {
          "@value": "Omaisuuskohteen informaatiomallin sisältö perustuu usein projektin informaatiomalliin, johon kuuluvat esimerkiksi suunnitelma- ja toteumamallin tiedot.",
          "@language": "fi"
        },
        {
          "@value": "Omaisuuskohteen informaatiomalli tukee omaisuudenhallintaa.",
          "@language": "fi"
        },
        {
          "@value": "Innehållet i tillgångsinformationsmodellen baseras ofta på projektets informationsmodell, som till exempel omfattar uppgifter från planerings- och genomförandemodeller.",
          "@language": "sv"
        },
        {
          "@value": "Tillgångsinformationsmodellen stödjer förvaltningen av tillgångar.",
          "@language": "sv"
        },
        {
          "@value": "The content of the asset information model is often based on the project information model, which includes for example information from design and as-built models.",
          "@language": "en"
        },
        {
          "@value": "The asset information model supports asset management.",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "RY-mallit sanasto",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/rymallit/c25"
        }
      ],
      "dcterms:created": {
        "@value": "2025-12-23T14:08",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2025-12-23T14:08",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/ontologia",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
