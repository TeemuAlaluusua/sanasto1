    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/alavirta",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "alavirta",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "nedströms",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "downstream",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "Toimitusketjun osa, joka kattaa vaiheet ja toimijat raaka-ainetoimittajista kokoonpanevaan tai tuottavaan yksikköön. Vastakohta ylävirralle. Käytetään myös nimitystä jakelumarkkinat.",
          "@language": "fi"
        }
      ],
      "skos:note": [
        {
          "@value": "Termiä käytetään toimitusketjun tarkastelussa kuvaamaan virtausta kohti\nkokoonpanoa tai tuotantoa. Rakentamisen kontekstissa alavirta voi tarkoittaa\nesimerkiksi materiaalien ja komponenttien toimitusketjua työmaalle tai\nelementtitehtaalle.\n",
          "@language": "fi"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Logistiikan maailma -termisanasto (2025)",
          "@id": "https://www.logistiikanmaailma.fi/aineistot/sanastot/logistiikan-maailma-termisanasto/"
        }
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/ylävirta"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-02-26T10:15:35",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/alfanumeerinen",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "alfanumeerinen",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "alfanumerisk",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "alphanumeric",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "aakkosnumeerinen",
          "@language": "fi",
          "termType": "Synonyymi"
        }
      ],
      "skos:definition": [
        {
          "@value": "Aakkosista (A–Z) ja numeroista (0–9) koostuva tai niitä sisältävä merkistö, koodi tai tieto. Vastakohtana pelkästään aakkosellinen tai pelkästään numeerinen.\n",
          "@language": "fi"
        }
      ],
      "skos:note": [
        {
          "@value": "Alfanumeerinen ei sisällä välimerkkejä tai erikoismerkkejä; jos myös niitä sallitaan, puhutaan esimerkiksi alfanumeerisesta ja erikoismerkkejä sisältävästä merkkijonosta tai laajennetusta merkistöstä.",
          "@language": "fi"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO/IEC 19762:2025. Information technology — Automatic identification and data capture techniques — Harmonized vocabulary"
        }
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-02-26T10:33:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/alkuperäisformaatti",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "alkuperäisformaatti",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "nativt format",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "native format",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "natiiviformaatti",
          "@language": "fi",
          "termType": "Synonyymi"
        },
        {
          "@value": "natiivimalli",
          "@language": "fi",
          "termType": "Synonyymi"
        },
        {
          "@value": "ursprungsformat",
          "@language": "sv",
          "termType": "Synonyymi"
        },
        {
          "@value": "nativt filformat",
          "@language": "sv",
          "termType": "Synonyymi"
        },
        {
          "@value": "native file format",
          "@language": "en",
          "termType": "Synonyymi"
        },
        {
          "@value": "proprietary format",
          "@language": "en",
          "termType": "Synonyymi"
        }
      ],
      "skos:definition": [
        {
          "@value": "Mallinnusohjelman oma tallennusformaatti. Rakennusalan julkaisuissa käytetään\ntälle synonyyminä käsitteitä natiivimalli tai natiiviformaatti.\n",
          "@language": "fi"
        },
        {
          "@value": "Det filformat som är specifikt för ett visst modelleringsprogram och dess\ninterna lagring av modellen. Inom byggbranschen används även benämningarna\nnativ modell eller nativt format som synonymer.\n",
          "@language": "sv"
        },
        {
          "@value": "The file format specific to a particular modelling software used for the\nmodel’s native storage. In the construction industry, the terms native model\nor native format are also used as synonyms.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "BEC:2023 Elementtisuunnittelun mallinnusohje",
          "@language": "fi",
          "@id": "https://www.elementtisuunnittelu.fi/Download/23982/BEC2012%20Elementtisuunnittelun%20mallinnusohje_v110.pdf"
        },
        {
          "@value": "YTV:2012 Yleiset tietomallivaatimukset",
          "@language": "fi",
          "@id": "https://wiki.buildingsmart.fi/fi/04_Julkaisut_ja_Standardit/YTV"
        }
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-02-27T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/anturi",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "anturi",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "sensor",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "sensor",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "sensori",
          "@language": "fi",
          "termType": "Synonyymi"
        },
        {
          "@value": "givare",
          "@language": "sv",
          "termType": "Synonyymi"
        },
        {
          "@value": "transducer",
          "@language": "en",
          "termType": "Synonyymi"
        }
      ],
      "skos:definition": [
        {
          "@value": "Anturi on laite, joka reagoi fyysiseen ärsykkeeseen kuten lämpöön, valoon,\nääneen, paineeseen, vetovoimaan tai liikkeeseen ja välittää sen arvon eteenpäin.\nAntureita hyödynnetään esimerkiksi erilaisissa IoT-ratkaisuissa.\n",
          "@language": "fi"
        },
        {
          "@value": "En sensor är en anordning som reagerar på en fysisk påverkan såsom värme, ljus,\nljud, tryck, gravitation eller rörelse och vidarebefordrar dess värde.\nSensorer används till exempel i olika IoT-lösningar.\n",
          "@language": "sv"
        },
        {
          "@value": "A sensor is a device that responds to a physical stimulus such as heat, light,\nsound, pressure, gravity or motion and transmits its value onward. Sensors are\nused, for example, in various IoT solutions.\n",
          "@language": "en"
        }
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-02-27T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/arvoketju",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "arvoketju",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "arvoverkko",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "värdekedja",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "värdenätverk",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "value chain",
          "@language": "en",
          "termType": "Suositettava termi"
        },
        {
          "@value": "value network",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "Toimintojen ja toimijoiden muodostama kokonaisuus,\njossa tuotteen tai palvelun arvo kasvaa vaiheittain.\n",
          "@language": "fi"
        },
        {
          "@value": "Helhet av aktiviteter eller aktörer som skapar eller mottar värde i form\nav produkter eller tjänster.\n",
          "@language": "sv"
        },
        {
          "@value": "Range of activities or parties that create or receive value in the form of products or services.\n",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Arvoverkosto tarkoittaa toimijoiden välisten suhteiden muodostamaa kokonaisuutta, jossa arvo syntyy useiden toimijoiden välisestä vuorovaikutuksesta ja vaihdannasta. Arvoverkostossa organisaatiot, ryhmät tai yksilöt tuottavat toisilleen sekä aineellista arvoa (esim. tuotteet, palvelut, raha) että aineetonta arvoa (esim. tieto, osaaminen, luottamus ja yhteistyö).\nToisin kuin arvoketju, arvoverkosto ei ole lineaarinen prosessi, vaan monisuuntainen ja dynaaminen verkosto, jossa toimijat ovat keskenään yhteydessä useilla eri tavoilla. Arvo syntyy toimijoiden välisissä suhteissa, yhteistyössä ja tiedonvaihdossa. Arvoverkosto voi muodostua esimerkiksi yritysten, julkisen sektorin toimijoiden, järjestöjen ja yksilöiden välisestä yhteistyöstä.\n",
          "@language": "fi"
        },
        {
          "@value": "Ett värdenätverk avser en helhet av relationer mellan aktörer där värde uppstår genom interaktion och utbyte mellan flera deltagare. I ett värdenätverk skapar organisationer, grupper eller individer både materiellt värde (t.ex. produkter, tjänster, pengar) och immateriellt värde (t.ex. information, kunskap, förtroende och samarbete) för varandra.\nTill skillnad från en värdekedja är ett värdenätverk inte en linjär process utan ett mångriktat och dynamiskt nätverk där aktörerna är förbundna med varandra på flera olika sätt. Värde uppstår genom relationer, samarbete och informationsutbyte mellan deltagarna. Ett värdenätverk kan till exempel bestå av samarbete mellan företag, aktörer inom den offentliga sektorn, organisationer och individer.\n",
          "@language": "sv"
        },
        {
          "@value": "A value network refers to a set of relationships between actors in which value is created through interaction and exchange among multiple participants. In a value network, organizations, groups, or individuals create both tangible value (e.g. products, services, money) and intangible value (e.g. information, knowledge, trust, and collaboration) for one another.\nUnlike a value chain, a value network is not a linear process but a multidirectional and dynamic network in which actors are connected in multiple ways. Value emerges through relationships, collaboration, and the exchange of information among participants. A value network may consist, for example, of cooperation between companies, public sector actors, organizations, and individuals.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO/PAS 24644-1:2023",
          "@language": "en",
          "@id": "https://standards.globalspec.com/std/14629302/pas-24644-1"
        }
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/toimitusketju",
        "https://teemualaluusua.github.io/sanasto1/liiketoimintaprosessi"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-02-27T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/asiakastilauksen-kytkeytymiskohta",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "asiakastilauksen kytkeytymiskohta",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "kundorderpunkt",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "customer order decoupling point",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "tilauskytkentäpiste",
          "@language": "fi",
          "termType": "Synonyymi"
        },
        {
          "@value": "tilauksen kytkeytymispiste",
          "@language": "fi",
          "termType": "Synonyymi"
        },
        {
          "@value": "kundorderkopplingspunkt",
          "@language": "sv",
          "termType": "Synonyymi"
        },
        {
          "@value": "order penetration point",
          "@language": "en",
          "termType": "Synonyymi"
        }
      ],
      "skos:definition": [
        {
          "@value": "Se toimitusketjun kohta, jossa tuote tai palvelu liitetään asiakkaan tekemään\ntilaukseen ja jossa toiminta muuttuu ennusteohjautuvasta tilausohjautuvaksi.\n",
          "@language": "fi"
        },
        {
          "@value": "Den punkt i leveranskedjan där en produkt eller tjänst kopplas till en kundorder\noch där styrningen övergår från prognosbaserad till orderstyrd.\n",
          "@language": "sv"
        },
        {
          "@value": "The point in the supply chain where a product or service is linked to a specific\ncustomer order and operations shift from forecast-driven to order-driven.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Logistiikan maailma -termisanasto:2025",
          "@language": "fi",
          "@id": "https://www.logistiikanmaailma.fi/aineistot/sanastot/logistiikan-maailma-termisanasto/"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/toimitusketju"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/arvoketju",
        "https://teemualaluusua.github.io/sanasto1/tilausohjautuva tuotanto",
        "https://teemualaluusua.github.io/sanasto1/ennusteohjautuva tuotanto"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-02-27T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/assosiaatio",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "assosiaatio",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "association",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "association",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "tietomallissa kahden luokan välillä oleva ei-hierarkkinen asiayhteys",
          "@language": "fi"
        },
        {
          "@value": "ett icke-hierarkiskt samband mellan två klasser i en datamodell",
          "@language": "sv"
        },
        {
          "@value": "non-hierarchical relationship between two classes in a data model",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Yhteentoimivuusalustan sanasto",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/yti/concept-23"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/tietomalli"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/luokka",
        "https://teemualaluusua.github.io/sanasto1/attribuutti",
        "https://teemualaluusua.github.io/sanasto1/käsiteskeema",
        "https://teemualaluusua.github.io/sanasto1/looginen tietomalli"
      ],
      "dcterms:created": {
