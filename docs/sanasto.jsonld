          "@value": "informaation vaihdon vaatimukset",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "krav för informationsutbyte",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "exchange information requirements",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "EIR",
          "@language": "fi",
