        }
      ],
      "skos:definition": [
        {
          "@value": "koneen ja ihmisen tulkittavissa oleva, yhteisesti sovittu, täsmällinen kuvaus sovellusalueen käsitteistä ja näiden välisistä suhteista",
          "@language": "fi"
        },
        {
          "@value": "Representation of a set of concepts within a domain and the relationships between those concepts",
          "@language": "en"
        }
      ],
      "dcterms:source": [
