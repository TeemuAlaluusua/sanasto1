        },
        {
          "@value": "EIR",
          "@language": "en",
          "termType": "Lyhenne"
        }
      ],
      "skos:definition": [
        {
          "@value": "Informaation vaihdon vaatimukset suhteessa toimeksiantoon.",
          "@language": "fi"
        },
        {
          "@value": "Krav för informationsutbyte i förhållande till uppdraget.",
          "@language": "sv"
        },
        {
          "@value": "Information exchange requirements in relation to the assignment.",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
