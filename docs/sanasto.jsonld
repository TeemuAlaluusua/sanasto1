        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-13T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/attribuutti",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "attribuutti",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "attribut",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "attribute",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "attribuuttitieto",
          "@language": "fi",
          "termType": "Synonyymi"
        },
        {
          "@value": "attributdata",
          "@language": "sv",
          "termType": "Synonyymi"
        }
      ],
      "skos:definition": [
        {
          "@value": "tietomallissa luokkaa luonnehtiva tai kuvaava ominaisuus\n",
          "@language": "fi"
        },
        {
          "@value": "egenskap i en informationsmodell som beskriver eller kännetecknar en klass\n",
          "@language": "sv"
        },
        {
          "@value": "characteristic in an information model that describes or characterizes a class\n",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Attribuutti on tietomallissa objektin määrittelyyn\nkuuluva rakenteellinen tietokenttä, joka kuvaa objektin ominaisuutta.\nAttribuutti on osa objektin luokan rakennetta ja sillä on ennalta\nmääritelty merkitys ja tietotyyppi. Esimerkkejä ovat nimi, tunnus,\nsijainti, tyyppi tai materiaali.\n\nTietomallinnuksessa attribuutti erotetaan usein ominaisuudesta\n(engl. property). Attribuutti on objektin luokan sisäinen,\nrakenteellinen kenttä, kun taas ominaisuus on yleensä erillinen,\nlaajennettava ominaisuustieto (esim. BIM-propertysetissä).\n",
          "@language": "fi"
        },
        {
          "@value": "Ett attribut är i en informationsmodell ett strukturellt\ndatafält som ingår i definitionen av ett objekt och beskriver en egenskap\nhos objektet. Attributet är en del av objektklassens struktur och har en\nfördefinierad betydelse och datatyp. Exempel är namn, identifierare,\nläge, typ eller material.\n\nI informationsmodellering skiljer man ofta mellan attribut och egenskap\n(eng. property). Ett attribut är ett internt, strukturellt fält i en\nobjektklass, medan en egenskap vanligtvis är en separat och utbyggbar\negenskapsuppgift (t.ex. i ett BIM-propertyset).\n",
          "@language": "sv"
        },
        {
          "@value": "An attribute is a structural data field in an information model that is\npart of the definition of an object and describes a characteristic of that\nobject. An attribute belongs to the structure of an object class and has a\npredefined meaning and data type. Examples include name, identifier,\nlocation, type, or material.\n\nIn information modelling, an attribute is often distinguished from a\nproperty. An attribute is an internal structural field of an object class,\nwhereas a property is typically a separate and extensible piece of\ndescriptive information (for example in a BIM property set).\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "RYHTI-sanasto",
          "@language": "fi",
          "@id": "https://ryhti.syke.fi/ohjeet-ja-tuki/ryhti-sanasto/"
        },
        {
          "@value": "Sanastot.suomi.fi",
          "@language": "fi",
          "@id": "https://sanastot.suomi.fi/terminology/yti/concept/concept-24"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/objekti"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/ominaisuus",
        "https://teemualaluusua.github.io/sanasto1/attribuutin-arvo",
        "https://teemualaluusua.github.io/sanasto1/tietokenttä"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-02-27T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
