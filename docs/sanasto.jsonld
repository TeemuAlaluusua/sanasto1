        "@value": "2026-03-17T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/luokitus",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "luokitus",
          "@language": "fi",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "klassificering",
          "@language": "sv",
          "termType": "Synonyymi"
        },
        {
          "@value": "classification",
          "@language": "en",
          "termType": "Synonyymi"
        }
      ],
      "skos:definition": [
        {
          "@value": "looginen järjestelmä, jossa asiat tai esineet on jaettu luokkiin niiden yhteisten tunnusmerkkien ja eroavaisuuksien mukaisesti",
          "@language": "fi"
        },
        {
          "@value": "logiskt system där saker eller objekt delas in i klasser enligt deras gemensamma kännetecken och skillnader",
          "@language": "sv"
        },
        {
          "@value": "logical system in which things or objects are divided into classes according to their shared characteristics and differences",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Yhteentoimivuusalustan sanasto",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/yti/concept-17"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/tietomääritys"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/luokka",
        "https://teemualaluusua.github.io/sanasto1/ontologia",
        "https://teemualaluusua.github.io/sanasto1/sanasto",
        "https://teemualaluusua.github.io/sanasto1/koodisto"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-17T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/luokka",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "luokka",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "klass",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "class",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "attribuuteista koostuva reaalimaailman kohteen vastine tietomallissa",
          "@language": "fi"
        },
        {
          "@value": "en motsvarighet i en datamodell till ett verkligt objekt som består av attribut",
          "@language": "sv"
        },
        {
          "@value": "representation in a data model of a real-world object composed of attributes",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Description of a set of objects that share the same properties, constraints, and semantics",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Yhteentoimivuusalustan sanasto",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/yti/concept-25"
        },
        {
          "@value": "UML 2.1.2 (modified)",
          "@language": "en",
          "@id": "https://www.omg.org/spec/UML/2.1.2/"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/tietomalli"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/attribuutti",
        "https://teemualaluusua.github.io/sanasto1/objekti",
        "https://teemualaluusua.github.io/sanasto1/entiteetti",
        "https://teemualaluusua.github.io/sanasto1/käsiteskeema"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-17T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/lupamalli",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "lupamalli",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "informationsmodell för byggnadslov",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "information model for building permit",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "rakennuskohteen informaatiomalli, joka sisältää ne suunnitelmamallin tiedot, joita tarvitaan rakentamislupaprosessin aikana",
          "@language": "fi"
        },
        {
          "@value": "informationsmodell för ett byggnadsobjekt som innehåller de uppgifter ur en projekteringsmodell som behövs under bygglovsprocessen",
          "@language": "sv"
        },
        {
          "@value": "information model of a building asset containing the information from the design model required during the building permit process",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Rakentamislupahakemuksessa ei välttämättä toimiteta\nerityissuunnitelmia, mutta niitä voidaan edellyttää\ntoimitettavaksi rakentamislupaprosessin aikana ennen\nrakennustyön aloittamista.\n",
          "@language": "fi"
        },
        {
          "@value": "Särskilda projekteringshandlingar behöver inte alltid\nlämnas in tillsammans med bygglovsansökan, men de kan\nkrävas under bygglovsprocessen innan byggarbetet påbörjas.\n",
          "@language": "sv"
        },
        {
          "@value": "Detailed discipline design documents may not always be\nsubmitted with the building permit application, but they\nmay be required during the permit process before\nconstruction work begins.\n",
          "@language": "en"
        },
        {
          "@value": "Lupamallin tulee noudattaa rakentamisen lupapäätösten\ntietomallia. Lupamalli voidaan toimittaa esimerkiksi\nSFS-EN ISO 16739-1 -standardin mukaisessa IFC-muodossa\n(Industry Foundation Classes).\n",
          "@language": "fi"
        },
        {
          "@value": "Informationsmodellen för bygglov ska följa datamodellen\nför bygglovsbeslut. Den kan till exempel levereras i\nIFC-format enligt standarden SFS-EN ISO 16739-1.\n",
          "@language": "sv"
        },
        {
          "@value": "The building permit information model shall follow the\ndata model for building permit decisions. It may be\ndelivered for example in IFC format according to\nSFS-EN ISO 16739-1 (Industry Foundation Classes).\n",
          "@language": "en"
        },
        {
          "@value": "Käsitejärjestelmäkaavio:\nhttps://sanastokeskus.fi/suomi.fi/rymallit/tietomalli.svg\n",
          "@language": "fi"
        },
        {
          "@value": "Begreppssystemdiagram:\nhttps://sanastokeskus.fi/suomi.fi/rymallit/tietomalli.svg\n",
          "@language": "sv"
        },
        {
          "@value": "Concept system diagram:\nhttps://sanastokeskus.fi/suomi.fi/rymallit/tietomalli.svg\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Suomi.fi-sanasto – RY-mallit",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/rymallit/c18"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/rakennuskohteen informaatiomalli"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/suunnitelmamalli",
        "https://teemualaluusua.github.io/sanasto1/rakentamislupa",
        "https://teemualaluusua.github.io/sanasto1/IFC"
      ],
      "dcterms:created": {
        "@value": "2025-12-23T14:08",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/malli",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "malli",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "modell",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "model",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "Fyysinen, matemaattinen tai muuten looginen esitys\njärjestelmästä, entiteetistä, ilmiöstä, prosessista\ntai datasta.\n",
          "@language": "fi"
        },
        {
          "@value": "Fysisk, matematisk eller på annat sätt logisk\nrepresentation av ett system, en entitet, ett\nfenomen, en process eller data.\n",
          "@language": "sv"
        },
        {
          "@value": "Physical, mathematical or otherwise logical\nrepresentation of a system, entity, phenomenon,\nprocess or data.\n",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Mallia käytetään kohteen kuvaamiseen, analysointiin,\nsimulointiin tai suunnitteluun.\n",
          "@language": "fi"
        },
        {
          "@value": "En modell används för att beskriva, analysera,\nsimulera eller planera ett system eller fenomen.\n",
          "@language": "sv"
        },
        {
          "@value": "A model is commonly used to describe, analyze,\nsimulate or design a system or phenomenon.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO/IEC 22989:2023",
          "@language": "en",
          "@id": "https://www.iso.org"
        }
      ],
      "skos:narrower": [
        "https://teemualaluusua.github.io/sanasto1/käsitemalli",
        "https://teemualaluusua.github.io/sanasto1/tietomalli",
        "https://teemualaluusua.github.io/sanasto1/matemaattinen malli"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/simulointi",
        "https://teemualaluusua.github.io/sanasto1/järjestelmä"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/mallinnus",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "mallinnus",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "modellering",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "modelling",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "prosessi, jossa kohteesta muodostetaan malli",
          "@language": "fi"
        },
        {
          "@value": "process där en modell skapas av ett objekt eller fenomen",
          "@language": "sv"
        },
        {
          "@value": "process of creating a model of an object or phenomenon",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Mallinnusta käytetään esimerkiksi järjestelmien,\nprosessien, rakenteiden tai tietojen kuvaamiseen.\n",
          "@language": "fi"
        },
        {
          "@value": "Modellering används till exempel för att beskriva\nsystem, processer, strukturer eller data.\n",
          "@language": "sv"
        },
        {
          "@value": "Modelling is used to describe systems, processes,\nstructures or data.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Suomi.fi-sanasto – RY-mallit",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/rymallit/c1"
        }
      ],
      "skos:narrower": [
        "https://teemualaluusua.github.io/sanasto1/tietomallinnus",
        "https://teemualaluusua.github.io/sanasto1/informaatiomallinnus"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/malli",
        "https://teemualaluusua.github.io/sanasto1/tietomalli",
        "https://teemualaluusua.github.io/sanasto1/informaatiomalli"
      ],
      "dcterms:created": {
        "@value": "2025-12-23T14:08",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/mappaus",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "vastaavuusmäärittely",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "mappning",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "mapping",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "mappaus",
          "@language": "fi",
          "termType": "Synonyymi"
        },
        {
          "@value": "semanttinen mappaus",
          "@language": "fi",
          "termType": "Synonyymi"
        },
        {
          "@value": "semantisk mappning",
          "@language": "sv",
          "termType": "Synonyymi"
        }
      ],
      "skos:definition": [
        {
          "@value": "Yhteen joukkoon kuuluvan elementin rinnastaminen\ntoisen joukon elementtiin semanttisen vastaavuuden\nperusteella.\n",
          "@language": "fi"
        },
        {
          "@value": "Koppling av ett element i en mängd till ett element\ni en annan mängd baserat på semantisk motsvarighet.\n",
          "@language": "sv"
        },
        {
          "@value": "Assigning an element in one set to an element in\nanother set through semantic correspondence.\n",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Vastaavuusmäärittelyssä selvitetään kahden eri\njoukon elementtien väliset semanttiset vastaavuudet.\n",
          "@language": "fi"
        },
        {
          "@value": "Vid mappning fastställs de semantiska\nmotsvarigheterna mellan element i två olika mängder.\n",
          "@language": "sv"
        },
        {
          "@value": "Mapping establishes the semantic correspondence\nbetween elements of two different sets.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO 5127:2022",
          "@language": "en",
          "@id": "https://www.iso.org/standard/59743.html"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/semanttinen vastaavuus"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/ontologia",
        "https://teemualaluusua.github.io/sanasto1/tietomalli",
        "https://teemualaluusua.github.io/sanasto1/skeema"
      ],
      "dcterms:created": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/mbom",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "valmistuksen tuoteosaluettelo",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "tillverkningsmateriallista",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "manufacturing bill of material",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "mBOM",
          "@language": "fi",
          "termType": "Lyhenne"
        },
        {
          "@value": "mBOM",
          "@language": "sv",
          "termType": "Lyhenne"
        },
        {
          "@value": "mBOM",
          "@language": "en",
          "termType": "Lyhenne"
        }
      ],
      "skos:definition": [
        {
          "@value": "Luettelo kaikista osista, tarroista, pakkauksista ja\nkokoonpanoista, joita tarvitaan valmiin tuotteen\nvalmistamiseen ja toimittamiseen asiakkaalle.\n",
          "@language": "fi"
        },
        {
          "@value": "Lista över alla delar, etiketter, förpackningar och\nsammansättningar som krävs för att tillverka och leverera\nen färdig produkt till kunden.\n",
          "@language": "sv"
        },
        {
          "@value": "List of all the parts, labels, packaging, and assemblies\nrequired to build and ship a finished product to\ncustomers.\n",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Valmistuksen tuoteosaluettelo kuvaa tuotteen\nvalmistuksessa ja toimituksessa tarvittavat\nosat ja materiaalit (as-built). Se voi poiketa\nsuunnittelun tuoteosaluettelosta esimerkiksi\nvalmistusvaiheiden, pakkausten tai\ntuotantokohtaisten komponenttien vuoksi.\n",
          "@language": "fi"
        },
        {
          "@value": "Tillverkningsmateriallistan beskriver de delar\noch material som används vid tillverkning och\nleverans av produkten (as-built). Den kan skilja\nsig från konstruktionsmateriallistan på grund\nav produktionsprocesser, förpackningar eller\nproduktionsspecifika komponenter.\n",
          "@language": "sv"
        },
        {
          "@value": "A manufacturing bill of material describes the\ncomponents and materials used in manufacturing\nand delivery of the finished product (as-built).\nIt may differ from the engineering bill of\nmaterial due to manufacturing processes,\npackaging or production-specific components.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO/TR 3151-1:2023(E)",
          "@language": "en"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/bom"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/ebom",
        "https://teemualaluusua.github.io/sanasto1/tuotanto"
      ],
      "dcterms:created": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/metatieto",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "metatieto",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "metadata",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "metadata",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "tieto, joka kuvaa aineiston kontekstia, sisältöä tai rakennetta sekä ohjaa ja dokumentoi sen käsittelyä ja hallintaa",
          "@language": "fi"
        },
        {
          "@value": "information som beskriver ett materials kontext, innehåll eller struktur samt styr och dokumenterar dess hantering och förvaltning",
          "@language": "sv"
        },
        {
          "@value": "information that describes the context, content or structure of a resource and guides and documents its processing and management",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Metatieto on tietoa tiedosta.",
          "@language": "fi"
        },
        {
          "@value": "Metadata är data om data.",
          "@language": "sv"
        },
        {
          "@value": "Metadata is data about data.",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Yhteentoimivuusalustan sanasto",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/yti/concept-76"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/tieto"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/metatietoskeema",
        "https://teemualaluusua.github.io/sanasto1/tietomääritys",
        "https://teemualaluusua.github.io/sanasto1/tietomalli",
        "https://teemualaluusua.github.io/sanasto1/tietue"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
