    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/tietomallinnus",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "tietomallinnus",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "datamodellering",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "data modeling",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "mallinnus, jonka tuloksena syntyy tietomalli",
          "@language": "fi"
        },
        {
          "@value": "modellering vars resultat är en datamodell",
          "@language": "sv"
        },
        {
          "@value": "modelling whose result is a data model",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Tietomallinnus on yleensä vaiheittain etenevä prosessi.",
          "@language": "fi"
        },
        {
          "@value": "Käsitejärjestelmäkaavio:\nhttps://sanastokeskus.fi/suomi.fi/rymallit/tietomalli.svg\n",
          "@language": "fi"
        }
      ],
      "dcterms:source": [
