    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/ato",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "tilauksesta kokoonpano",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "kundorderstyrd montering",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "assemble-to-order",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "ATO",
          "@language": "fi",
          "termType": "Lyhenne"
        },
        {
          "@value": "asiakasohjautuva kokoonpano",
          "@language": "fi",
          "termType": "Synonyymi"
        },
        {
          "@value": "ATO",
          "@language": "sv",
          "termType": "Lyhenne"
        },
        {
          "@value": "ATO",
          "@language": "en",
          "termType": "Lyhenne"
        }
      ],
      "skos:definition": [
        {
          "@value": "Tuotanto- ja toimitusstrategia, jossa tuote kootaan asiakkaan\ntilauksen jälkeen varastoiduista vakiokomponenteista tai\nosakokoonpanoista. Komponentit valmistetaan tai hankitaan\netukäteen, mutta lopullinen kokoonpano tehdään vasta\nasiakastilauksen perusteella. Toimitusaika määräytyy\nkomponentti- ja osakokoonpanovaraston saatavuuden sekä\nkokoonpanoajan mukaan.\n",
          "@language": "fi"
        },
        {
          "@value": "Produktions- och leveransstrategi där produkten monteras efter\nkundorder från lagerhållna standardkomponenter eller\ndelmontage. Komponenterna tillverkas eller anskaffas i förväg,\nmen den slutliga monteringen sker först efter mottagen\nkundorder. Leveranstiden bestäms av tillgången på komponent-\noch delmontagelager samt monteringstiden.\n",
          "@language": "sv"
        },
        {
          "@value": "Production and fulfilment strategy in which a product is\nassembled after receipt of a customer order from stocked\nstandard components or subassemblies. Components are produced\nor procured in advance, while the final assembly is performed\nonly after the order is received. Lead time depends on the\navailability of components and subassemblies and the assembly\ntime.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Alaluusua 2023",
          "@language": "fi",
          "@id": "https://aaltodoc.aalto.fi/server/api/core/bitstreams/d55ffacc-a2d7-414b-8f8c-313dff01e984/content"
        },
        {
          "@value": "Peltokorpi 2020 Tuotetiedon hallinta ja hyödyntäminen",
          "@language": "fi",
          "@id": "https://www.aalto.fi/sites/default/files/2020-11/Loppuraportti_Tuotetiedon%20hallinta%20ja%20hyo%CC%88dynta%CC%88minen_2.11.2020_0.pdf"
        },
        {
          "@value": "ISO TR 3151-1",
          "@language": "en"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/tuotanto-ja-toimitusstrategia"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/asiakastilauksen-kytkeytymiskohta",
        "https://teemualaluusua.github.io/sanasto1/mts",
        "https://teemualaluusua.github.io/sanasto1/mto",
