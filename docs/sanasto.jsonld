      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/tietomallinnus",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "tietomallinnus",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "datamodellering",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "data modeling",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "mallinnus, jonka tuloksena syntyy tietomalli",
          "@language": "fi"
        },
        {
          "@value": "modellering vars resultat är en datamodell",
          "@language": "sv"
        },
        {
          "@value": "modelling whose result is a data model",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Tietomallinnus on yleensä vaiheittain etenevä prosessi.",
          "@language": "fi"
        },
        {
          "@value": "Käsitejärjestelmäkaavio:\nhttps://sanastokeskus.fi/suomi.fi/rymallit/tietomalli.svg\n",
          "@language": "fi"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Suomi.fi-sanasto – RY-mallit",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/rymallit/c2"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/mallinnus"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/tietomalli",
        "https://teemualaluusua.github.io/sanasto1/käsitemalli",
        "https://teemualaluusua.github.io/sanasto1/skeema"
      ],
      "dcterms:created": {
        "@value": "2025-12-23T14:08",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/tietopankki",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "tietopankki",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "databank",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "data repository",
          "@language": "en",
          "termType": "Suositettava termi"
        },
        {
          "@value": "data bank",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "joukko tiedostoja tai tietokantoja, joilla on yhteinen varastointijärjestelmä, käsittelyjärjestelmä ja hakujärjestelmä",
          "@language": "fi"
        },
        {
          "@value": "samling filer eller databaser som har ett gemensamt lagringssystem, behandlingssystem och söksystem",
          "@language": "sv"
        },
        {
          "@value": "set of files or databases combined with a storage system, a processing system and a retrieval system",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Tietopankki tarkoittaa järjestettyä kokonaisuutta, jossa tietoa\ntallennetaan, ylläpidetään ja haetaan yhtenäisen järjestelmän avulla.\nTermiä käytetään usein yleisnimityksenä järjestelmälle, joka kokoaa\nuseita tietokantoja tai tiedostoja yhteen hallittuun tietovarastoon.\n",
          "@language": "fi"
        },
        {
          "@value": "En databank är en organiserad helhet där information lagras, underhålls\noch hämtas med hjälp av ett enhetligt system. Termen används ofta som\nen allmän beteckning för ett system som samlar flera databaser eller\nfiler i ett gemensamt hanterat informationslager.\n",
          "@language": "sv"
        },
        {
          "@value": "A data repository or data bank refers to an organised collection in\nwhich information is stored, maintained and retrieved through a\nunified system. The term is often used as a general designation for a\nsystem that brings together several databases or files into a managed\ninformation storage environment.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO 5127:2022 Information and documentation — Foundation and vocabulary",
          "@language": "en",
          "@id": "https://www.iso.org/standard/59743.html"
        }
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/tietovaranto",
        "https://teemualaluusua.github.io/sanasto1/tietokanta",
        "https://teemualaluusua.github.io/sanasto1/tietovarasto"
      ],
      "dcterms:created": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/tietue",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "tietue",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "post",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "record",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "dokumentin osa tai dokumentti, joka sisältää rakenteellisen ja sisäisesti järjestetyn joukon itsenäistä mutta toisiinsa liittyvää dataa, joka koskee yhtä henkilöä tai muuta oliota ja joka on valittu ja esitetty tiettyä tarkoitusta varten",
          "@language": "fi"
        },
        {
          "@value": "del av ett dokument eller dokument som innehåller en strukturerad och internt organiserad uppsättning självständiga men relaterade data om en person eller annat objekt, valda och presenterade för ett specifikt syfte",
          "@language": "sv"
        },
        {
          "@value": "part of a document or document containing a structured and internally organized set of self-contained but related data on one person or other object, selected and presented for a predefined specific purpose",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Tietue koostuu yleensä useista kentistä,\njotka kuvaavat tietyn kohteen ominaisuuksia.\n",
          "@language": "fi"
        },
        {
          "@value": "En post består vanligtvis av flera fält\nsom beskriver egenskaper hos ett visst objekt.\n",
          "@language": "sv"
        },
        {
          "@value": "A record typically consists of several\nfields describing attributes of a given object.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO 5127:2022",
          "@language": "en",
          "@id": "https://www.iso.org"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/tietokanta"
      ],
      "skos:narrower": [
        "https://teemualaluusua.github.io/sanasto1/kenttä"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/tietokohde",
        "https://teemualaluusua.github.io/sanasto1/tietorakenne"
      ],
      "dcterms:created": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/vaihtoformaatti",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "vaihtoformaatti",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "utbytesformat",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "exchange format",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "koneluettava dataformaatti, jonka avulla tieto esitetään sellaisessa muodossa, jossa sitä voidaan vaihtaa eri sovellusten välillä",
          "@language": "fi"
        },
        {
          "@value": "maskinläsbart dataformat som används för att representera information i en form som möjliggör utbyte mellan olika applikationer",
          "@language": "sv"
        },
        {
          "@value": "machine-readable data format for representing information that is intended to facilitate exchange of the information between different applications",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Vaihtoformaatteja käytetään tietojen siirtämiseen\neri tietojärjestelmien tai ohjelmistojen välillä\nyhteentoimivuuden varmistamiseksi.\n",
          "@language": "fi"
        },
        {
          "@value": "Utbytesformat används för att överföra information\nmellan olika informationssystem eller programvara\nför att möjliggöra interoperabilitet.\n",
          "@language": "sv"
        },
        {
          "@value": "Exchange formats are used to transfer information\nbetween different information systems or software\napplications to enable interoperability.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO 5127:2022",
          "@language": "en",
          "@id": "https://www.iso.org/standard/59743.html"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/dataformaatti"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/tiedostoformaatti",
        "https://teemualaluusua.github.io/sanasto1/säilytysformaatti"
      ],
      "dcterms:created": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/ylävirta",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "ylävirta",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "uppströms",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "upstream",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "Toimitusketjun osa, joka kattaa vaiheet ja toimijat raaka-ainelähteistä ja toimittajista kokoonpanevaan tai tuottavaan yksikköön. Vastakohta alavirralle. Kutsutaan myös hankintapääksi tai hankintamarkkinoiksi.",
          "@language": "fi"
        },
        {
          "@value": "Den del av leveranskedjan som omfattar skeden och aktörer från råvarukällor och leverantörer till den producerande eller monterande enheten. Motsats till nedströms.",
          "@language": "sv"
        },
        {
          "@value": "The part of a supply chain that includes the stages and actors from raw material sources and suppliers to the producing or assembling unit. The opposite of downstream.",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Termiä käytetään toimitusketjun tarkastelussa kuvaamaan virtausta kohti\ntuotantoa tai kokoonpanoa. Rakentamisen kontekstissa ylävirta voi tarkoittaa\nesimerkiksi materiaalien ja komponenttien toimitusketjua raaka-aineista\nelementtitehtaalle tai työmaalle.\n",
          "@language": "fi"
        },
        {
          "@value": "Termen används vid analys av leveranskedjor för att beskriva flödet mot\nproduktion eller montering. I byggsektorn kan uppströms till exempel\navse leveranskedjan för material och komponenter från råvaror till\nelementfabrik eller byggarbetsplats.\n",
          "@language": "sv"
        },
        {
          "@value": "The term is used in supply chain analysis to describe the flow towards\nproduction or assembly. In the construction context, upstream may refer\nto the supply chain of materials and components from raw materials to a\nprefabrication plant or construction site.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Logistiikan maailma -termisanasto (2025)",
          "@language": "fi",
          "@id": "https://www.logistiikanmaailma.fi/aineistot/sanastot/logistiikan-maailma-termisanasto/"
        }
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/alavirta"
      ],
      "dcterms:created": {
        "@value": "2026-02-26T10:25:00",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-02-26T10:25:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/bop",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "valmistusprosessiluettelo",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "processlista för tillverkning",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "bill of process",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "BOP",
          "@language": "fi",
          "termType": "Lyhenne"
        },
        {
          "@value": "BOP",
          "@language": "sv",
          "termType": "Lyhenne"
        },
        {
          "@value": "BOP",
          "@language": "en",
          "termType": "Lyhenne"
        }
      ],
      "skos:definition": [
        {
          "@value": "luettelo tuotteen valmistamiseen tarvittavista valmistusvaiheista ja prosesseista",
          "@language": "fi"
        },
        {
          "@value": "förteckning över de processer och arbetsmoment som krävs för att tillverka en produkt",
          "@language": "sv"
        },
        {
          "@value": "list of manufacturing processes and operations required to produce a product",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "BOP kuvaa tuotteen valmistusprosessin rakenteen ja täydentää usein BOM-luetteloa.",
          "@language": "fi"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO/TR 3151-1:2023",
          "@language": "en",
          "@id": "https://www.iso.org/"
        }
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/bom",
        "https://teemualaluusua.github.io/sanasto1/mom",
        "https://teemualaluusua.github.io/sanasto1/plm"
      ]
    }
  ]
}