    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/säilytysformaatti",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "säilytysformaatti",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "lagringsformat",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "storage format",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "dataformaatti, jossa digitaalista dataa säilytetään tietokoneella tai pitkäaikaiseen varastointiin tarkoitetussa tietopankissa",
          "@language": "fi"
        },
        {
          "@value": "dataformat där digital data lagras i en dators primärminne eller i ett arkiv för långtidslagring",
          "@language": "sv"
        },
        {
          "@value": "data format for the hosting of digital data in the main store of a computer or in a long-term storage data repository",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Säilytysformaatti määrittelee, miten data\ntallennetaan ja säilytetään tietojärjestelmissä\ntai pitkäaikaissäilytyksessä.\n",
          "@language": "fi"
        },
        {
          "@value": "Ett lagringsformat anger hur data lagras\noch bevaras i informationssystem eller\ni långtidslagring.\n",
          "@language": "sv"
        },
        {
          "@value": "A storage format specifies how digital\ndata is stored and preserved in computer\nsystems or long-term storage repositories.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO 5127:2022",
          "@language": "en",
          "@id": "https://www.iso.org/standard/59743.html"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/dataformaatti"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/tiedostoformaatti",
        "https://teemualaluusua.github.io/sanasto1/tiedonsiirtoformaatti"
      ],
      "dcterms:created": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/skeema",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "skeema",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "schema",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "schema",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "rakennekuvaus, jonka mukaisella sanastolla voidaan kuvailla sillä tarkkuudella, että myös tietokoneet ymmärtävät sen",
          "@language": "fi"
        },
        {
          "@value": "strukturdefinition vars vokabulär gör det möjligt att beskriva information med sådan precision att även datorer kan tolka den",
          "@language": "sv"
        },
        {
          "@value": "structural specification that defines a vocabulary enabling information to be described with sufficient precision for computer interpretation",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "looginen suunnitelma, jossa esitetään metatietoelementtien väliset yhteydet\nyleensä määrittämällä säännöt metatietojen käytölle ja hallinnalle erityisesti\nsemantiikan, syntaksin ja arvojen valinnaisuuden (pakollisuusasteen) osalta\n",
          "@language": "fi"
        },
        {
          "@value": "logical plan showing the relationships between metadata elements, normally\nthrough establishing rules for the use and management of metadata specifically\nas regards the semantics, the syntax and the optionality (obligation level) of values\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Sanastot.fi – Yrityksen digitalous",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/yritysdigi/concept-2021"
        },
        {
          "@value": "ISO 23081-1:2006",
          "@language": "en",
          "@id": "https://www.iso.org/"
        }
      ],
      "skos:narrower": [
        "https://teemualaluusua.github.io/sanasto1/käsiteskeema",
        "https://teemualaluusua.github.io/sanasto1/metatietoskeema"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/tietomalli"
      ],
      "dcterms:created": {
        "@value": "2026-02-24T17:35",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-14T00:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/skos",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "simple knowledge organization system",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "simple knowledge organization system",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "simple knowledge organization system",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:altLabel": [
        {
          "@value": "SKOS",
          "@language": "fi",
          "termType": "Lyhenne"
        },
        {
          "@value": "SKOS",
          "@language": "sv",
          "termType": "Lyhenne"
        },
        {
          "@value": "SKOS",
          "@language": "en",
          "termType": "Lyhenne"
        }
      ],
      "skos:definition": [
        {
          "@value": "Yleinen tietomalli, jonka avulla jaetaan ja linkitetään\ntietämysalkioita internetissä.\n",
          "@language": "fi"
        },
        {
          "@value": "En gemensam datamodell för att dela och länka\nkunskapsobjekt på internet.\n",
          "@language": "sv"
        },
        {
          "@value": "Common data model for sharing and linking\nknowledge items via the internet.\n",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "SKOS on W3C:n suositus sanastojen, tesaurusten ja\nluokitusjärjestelmien esittämiseen RDF-muodossa.\n",
          "@language": "fi"
        },
        {
          "@value": "SKOS är en W3C-rekommendation för att representera\ntesaurer, klassifikationssystem och andra vokabulärer i RDF.\n",
          "@language": "sv"
        },
        {
          "@value": "SKOS is a W3C recommendation used to represent\nthesauri, classification schemes and other vocabularies in RDF.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "SKOS Simple Knowledge Organization System Reference",
          "@id": "https://www.w3.org/TR/skos-reference/"
        },
        {
          "@value": "ISO 5127:2022"
        }
      ],
      "dcterms:created": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/tiedon louhinta",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "tiedon louhinta",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "datautvinning",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "data mining",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "tietokoneperusteiset tiedonhakutoimenpiteet, joiden avulla tunnistetaan malleja analysoimalla kvantitatiivista dataa eri näkökulmista ja ulottuvuuksista, kategorisoidaan sitä ja tehdään yhteenvetoja potentiaalisista suhteista ja vaikutuksista",
          "@language": "fi"
        },
        {
          "@value": "datorbaserad process för informationssökning och analys där mönster identifieras genom att analysera kvantitativa data från olika perspektiv och dimensioner, kategorisera dem och sammanfatta potentiella samband och effekter",
          "@language": "sv"
        },
        {
          "@value": "computational search and retrieval process that identifies patterns by analysing quantitative data from different perspectives and dimensions, categorizing it, and summarizing potential relationships and impacts",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Tiedon louhintaa käytetään esimerkiksi suurten\ntietoaineistojen analysoinnissa, ennusteiden\ntekemisessä sekä piilevien riippuvuuksien\ntunnistamisessa datasta.\n",
          "@language": "fi"
        },
        {
          "@value": "Datautvinning används till exempel för analys\nav stora datamängder, för att göra prognoser\noch för att identifiera dolda samband i data.\n",
          "@language": "sv"
        },
        {
          "@value": "Data mining is commonly used to analyse large\ndatasets, discover hidden patterns and support\npredictive analytics.\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO 5127:2022",
          "@language": "en",
          "@id": "https://www.iso.org"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/data-analytiikka"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/big-data",
        "https://teemualaluusua.github.io/sanasto1/koneoppiminen",
        "https://teemualaluusua.github.io/sanasto1/tilastollinen analyysi"
      ],
      "dcterms:created": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/tietokanta",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "tietokanta",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "databas",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "database",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "kokoelma koneluettavaa tietoa, joka on järjestetty niin, että siihen on helppo pääsy ja sitä on helppo hallita ja päivittää",
          "@language": "fi"
        },
        {
          "@value": "samling maskinläsbar information organiserad så att den lätt kan nås, hanteras och uppdateras",
          "@language": "sv"
        },
        {
          "@value": "collection of machine-readable information organized so that it can be easily accessed, managed and updated",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Tietokanta on yleensä hallittu tietovaranto,\njota ylläpidetään tietokannanhallintajärjestelmän\n(DBMS) avulla.\n",
          "@language": "fi"
        },
        {
          "@value": "En databas är vanligtvis ett informationslager\nsom hanteras med hjälp av ett databashanteringssystem\n(DBMS).\n",
          "@language": "sv"
        },
        {
          "@value": "A database is typically maintained using a\ndatabase management system (DBMS).\n",
          "@language": "en"
        }
      ],
      "dcterms:source": [
        {
          "@value": "ISO 5127:2022",
          "@language": "en",
          "@id": "https://www.iso.org"
        }
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/tietokannanhallintajärjestelmä",
        "https://teemualaluusua.github.io/sanasto1/tietovaranto",
        "https://teemualaluusua.github.io/sanasto1/tietomalli"
      ],
      "dcterms:created": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      },
      "dcterms:modified": {
        "@value": "2026-03-05T12:00",
        "@type": "xsd:dateTime"
      }
    },
    {
      "@id": "https://teemualaluusua.github.io/sanasto1/#/concept/tietomalli",
      "@type": "skos:Concept",
      "skos:inScheme": "https://teemualaluusua.github.io/sanasto1/sanasto",
      "skos:prefLabel": [
        {
          "@value": "tietomalli",
          "@language": "fi",
          "termType": "Suositettava termi"
        },
        {
          "@value": "datamodell",
          "@language": "sv",
          "termType": "Suositettava termi"
        },
        {
          "@value": "data model",
          "@language": "en",
          "termType": "Suositettava termi"
        }
      ],
      "skos:definition": [
        {
          "@value": "malli, joka kuvaa tiedot ja tietojen väliset suhteet rakenteisessa muodossa",
          "@language": "fi"
        },
        {
          "@value": "modell som beskriver data och relationerna mellan data i strukturerad form",
          "@language": "sv"
        },
        {
          "@value": "model that describes data and the relationships between data in a structured form",
          "@language": "en"
        }
      ],
      "skos:note": [
        {
          "@value": "Käsitejärjestelmäkaavio:\nhttps://sanastokeskus.fi/suomi.fi/rymallit/tietomalli.svg\n",
          "@language": "fi"
        }
      ],
      "dcterms:source": [
        {
          "@value": "Suomi.fi-sanasto – RY-mallit",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/rymallit/c6"
        },
        {
          "@value": "Yhteentoimivuusalusta (YTI)",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/yti/concept-22"
        },
        {
          "@value": "Rakennetun ympäristön sanasto",
          "@language": "fi",
          "@id": "https://iri.suomi.fi/terminology/rakymp/c97"
        }
      ],
      "skos:broader": [
        "https://teemualaluusua.github.io/sanasto1/malli"
      ],
      "skos:narrower": [
        "https://teemualaluusua.github.io/sanasto1/käsitemalli",
        "https://teemualaluusua.github.io/sanasto1/looginen tietomalli",
        "https://teemualaluusua.github.io/sanasto1/fyysinen tietomalli"
      ],
      "skos:related": [
        "https://teemualaluusua.github.io/sanasto1/skeema",
        "https://teemualaluusua.github.io/sanasto1/ontologia",
        "https://teemualaluusua.github.io/sanasto1/metatietoskeema"
      ],
      "dcterms:created": {
        "@value": "2025-12-23T14:08",
